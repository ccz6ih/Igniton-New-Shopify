{%- comment -%}
  IG Section Controls
  ───────────────────
  Emits a scoped <style> block writing BOTH CSS custom properties
  and direct font-size/color rules scoped to #shopify-section-{id}.

  Direct rules use ID-scoped selectors (specificity 0,1,1,0) to
  guarantee they override any inherited or lower-specificity rules.

  USAGE
  -----
    {% render 'ig-section-controls', section: section %}
{%- endcomment -%}

{%- assign s = section.settings -%}

{%- comment -%} Container width mapping {%- endcomment -%}
{%- assign cw = s.container_width | default: 'default' -%}
{%- case cw -%}
  {%- when 'narrow' -%}{%- assign container_width = '720px' -%}
  {%- when 'medium' -%}{%- assign container_width = '960px' -%}
  {%- when 'wide'   -%}{%- assign container_width = '1440px' -%}
  {%- when 'full'   -%}{%- assign container_width = '100%' -%}
  {%- else          -%}{%- assign container_width = '1200px' -%}
{%- endcase -%}

{%- assign pad_start   = s.padding_block_start_desktop | default: 96 -%}
{%- assign pad_end     = s.padding_block_end_desktop   | default: 96 -%}
{%- assign pad_start_m = s.padding_block_start_mobile  | default: 48 -%}
{%- assign pad_end_m   = s.padding_block_end_mobile    | default: 48 -%}

{%- assign label_size_pct = s.label_size    | default: 100  -%}
{%- assign label_scale    = label_size_pct  | divided_by: 100.0 -%}
{%- assign label_spacing  = s.label_spacing | default: 0.75 -%}

{%- assign heading_size     = s.heading_size         | default: 3.5 -%}
{%- assign heading_width    = s.heading_max_width    | default: 900 -%}
{%- assign heading_spacing  = s.heading_spacing      | default: 2.5 -%}
{%- assign mobile_scale_pct = s.mobile_heading_scale | default: 65 -%}
{%- assign mobile_scale     = mobile_scale_pct | divided_by: 100.0 -%}
{%- assign heading_mobile   = heading_size | times: mobile_scale -%}

{%- assign body_size  = s.body_size      | default: 1 -%}
{%- assign body_width = s.body_max_width | default: 640 -%}

{%- style -%}
  /* ─── CSS custom properties ─── */
  #shopify-section-{{ section.id }} {
    --ig-container-width: {{ container_width }};
    --ig-pad-start:       {{ pad_start }}px;
    --ig-pad-end:         {{ pad_end }}px;
    --ig-pad-start-m:     {{ pad_start_m }}px;
    --ig-pad-end-m:       {{ pad_end_m }}px;
    --ig-label-scale:     {{ label_scale }};
    --ig-label-spacing:   {{ label_spacing }}rem;
    --ig-heading-size:    {{ heading_size }}rem;
    --ig-heading-width:   {{ heading_width }}px;
    --ig-heading-spacing: {{ heading_spacing }}rem;
    --ig-mobile-scale:    {{ mobile_scale }};
    --ig-body-size:       {{ body_size }}rem;
    --ig-body-width:      {{ body_width }}px;
  }

  /* ─── Direct font-size + color rules (ID-scoped for specificity) ─── */

  /* Eyebrow label */
  #shopify-section-{{ section.id }} .ig-section-label {
    font-size: calc(0.8125rem * {{ label_scale }});
    margin-bottom: {{ label_spacing }}rem;
    color: rgb(var(--color-foreground));
  }

  /* Section heading */
  #shopify-section-{{ section.id }} .ig-section-title {
    font-size: {{ heading_mobile }}rem;
    max-width: {{ heading_width }}px;
    margin-bottom: {{ heading_spacing }}rem;
    color: rgb(var(--color-foreground));
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .ig-section-title {
      font-size: {{ heading_size }}rem;
    }
  }

  /* Body-sized elements — any child with class .ig-section-body scales with the Body size slider */
  #shopify-section-{{ section.id }} .ig-section-body {
    font-size: {{ body_size }}rem;
  }
{%- endstyle -%}
