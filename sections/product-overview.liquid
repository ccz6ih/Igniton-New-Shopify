{{ 'component-product-overview.css' | asset_url | stylesheet_tag }}

{% render 'ig-section-controls', section: section %}

{%- liquid
  assign tab_anchor = section.settings.tab_anchor | default: 'overview' | handleize
  assign heading_level = section.settings.heading_level | default: '2' | plus: 0
-%}

<section
  id="{{ tab_anchor }}"
  class="pdp-tab-panel product-overview color-{{ section.settings.color_scheme }}"
  {% if section.settings.is_default_tab %}data-tab-default="true"{% endif %}
  role="tabpanel"
  aria-labelledby="{{ tab_anchor }}-tab"
>
  <div class="product-overview__container">
    {%- if section.settings.section_label != blank -%}
      <p class="ig-section-label{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
        {{ section.settings.section_label }}
      </p>
    {%- endif -%}

    {%- if section.settings.section_heading != blank -%}
      {%- case heading_level -%}
        {%- when 2 -%}
          <h2 class="ig-section-title{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">{{ section.settings.section_heading }}</h2>
        {%- when 3 -%}
          <h3 class="ig-section-title{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">{{ section.settings.section_heading }}</h3>
        {%- when 4 -%}
          <h4 class="ig-section-title{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">{{ section.settings.section_heading }}</h4>
        {%- when 5 -%}
          <h5 class="ig-section-title{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">{{ section.settings.section_heading }}</h5>
        {%- when 6 -%}
          <h6 class="ig-section-title{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">{{ section.settings.section_heading }}</h6>
      {%- endcase -%}
    {%- endif -%}

    <div
      class="product-overview__grid product-overview__grid--cols-{% if section.settings.show_benefits_column and section.settings.show_timeline_column %}2{% else %}1{% endif %}"
    >
      {%- if section.settings.show_benefits_column -%}
        <div class="product-overview__benefits">
          {%- if section.settings.benefits_heading != blank -%}
            <h3 class="product-overview__col-heading">{{ section.settings.benefits_heading }}</h3>
          {%- endif -%}
          <ul class="product-overview__benefit-list" role="list">
            {%- for block in section.blocks -%}
              {%- if block.type == 'benefit' -%}
                <li class="product-overview__benefit ig-section-body" {{ block.shopify_attributes }}>
                  <span class="product-overview__benefit-icon" aria-hidden="true">
                    {{- block.settings.icon | default: '✓' -}}
                  </span>
                  <span class="product-overview__benefit-text">{{ block.settings.text }}</span>
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}

      {%- if section.settings.show_timeline_column -%}
        <div class="product-overview__timeline">
          {%- if section.settings.timeline_heading != blank -%}
            <h3 class="product-overview__col-heading">{{ section.settings.timeline_heading }}</h3>
          {%- endif -%}
          <ol class="product-overview__timeline-list" role="list">
            {%- for block in section.blocks -%}
              {%- if block.type == 'timeline_step' -%}
                <li class="product-overview__timeline-step" {{ block.shopify_attributes }}>
                  <div class="product-overview__timeline-time ig-section-label">
                    {{- block.settings.time_label -}}
                  </div>
                  <h4 class="product-overview__timeline-title">{{ block.settings.title }}</h4>
                  <p class="product-overview__timeline-desc ig-section-body">{{ block.settings.description }}</p>
                  {%- if block.settings.progress_pct != blank -%}
                    {%- assign progress_raw = block.settings.progress_pct | plus: 0 -%}
                    {%- if progress_raw < 0 -%}
                      {%- assign progress = 0 -%}
                    {%- elsif progress_raw > 100 -%}
                      {%- assign progress = 100 -%}
                    {%- else -%}
                      {%- assign progress = progress_raw -%}
                    {%- endif -%}
                    <div
                      class="product-overview__progress"
                      role="progressbar"
                      aria-valuenow="{{ progress }}"
                      aria-valuemin="0"
                      aria-valuemax="100"
                      aria-label="{{ progress }}% progress"
                    >
                      <div
                        class="product-overview__progress-fill"
                        style="width: {{ progress }}%;"
                        aria-hidden="true"
                      ></div>
                    </div>
                  {%- endif -%}
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ol>
        </div>
      {%- endif -%}
    </div>

    {%- if section.settings.show_usage_callout -%}
      <aside class="product-overview__usage" aria-label="{{ section.settings.usage_title | default: 'How to take' | escape }}">
        {%- if section.settings.usage_title != blank -%}
          <h3 class="product-overview__usage-title">{{ section.settings.usage_title }}</h3>
        {%- endif -%}
        {%- if section.settings.usage_body != blank -%}
          <div class="product-overview__usage-body ig-section-body rte">{{ section.settings.usage_body }}</div>
        {%- endif -%}
        {%- if section.settings.usage_warnings != blank -%}
          {%- assign warn_lines = section.settings.usage_warnings | newline_to_br | split: '<br />' -%}
          <ul class="product-overview__warnings" role="list">
            {%- for line in warn_lines -%}
              {%- assign clean = line | strip -%}
              {%- if clean != blank -%}
                <li class="product-overview__warning ig-section-body">{{ clean }}</li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </aside>
    {%- endif -%}
  </div>
</section>

{% schema %}
