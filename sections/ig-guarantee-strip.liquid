{{ 'component-ig-guarantee-strip.css' | asset_url | stylesheet_tag }}

{% render 'ig-section-controls', section: section %}

<section
  id="IgGuaranteeStrip-{{ section.id }}"
  class="ig-guarantee-strip color-{{ section.settings.color_scheme }}"
>
  <div class="ig-guarantee-strip__container">
    {%- if section.settings.icon != blank -%}
      <span class="ig-guarantee-strip__icon">{{ section.settings.icon }}</span>
    {%- endif -%}

    {%- if section.settings.guarantee_text != blank -%}
      <div class="ig-guarantee-strip__text ig-section-body ig-font-body">
        {{ section.settings.guarantee_text }}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Igniton Guarantee Strip",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Color"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1",
      "info": "Stripe background uses the scheme's button color so the gold accent stripe survives any scheme choice."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "options": [
        { "value": "narrow",  "label": "Narrow (720px)" },
        { "value": "medium",  "label": "Medium (960px)" },
        { "value": "default", "label": "Default (1200px)" },
        { "value": "wide",    "label": "Wide (1440px)" },
        { "value": "full",    "label": "Full bleed" }
      ],
      "default": "full"
    },
    {
      "type": "header",
      "content": "Spacing — desktop"
    },
    {
      "type": "range",
      "id": "padding_block_start_desktop",
      "min": 0, "max": 200, "step": 4,
      "unit": "px",
      "default": 24,
      "label": "Top padding (desktop)"
    },
    {
      "type": "range",
      "id": "padding_block_end_desktop",
      "min": 0, "max": 200, "step": 4,
      "unit": "px",
      "default": 24,
      "label": "Bottom padding (desktop)"
    },
    {
      "type": "header",
      "content": "Spacing — mobile"
    },
    {
      "type": "range",
      "id": "padding_block_start_mobile",
      "min": 0, "max": 200, "step": 4,
      "unit": "px",
      "default": 20,
      "label": "Top padding (mobile)"
    },
    {
      "type": "range",
      "id": "padding_block_end_mobile",
      "min": 0, "max": 200, "step": 4,
      "unit": "px",
      "default": 20,
      "label": "Bottom padding (mobile)"
    },
    {
      "type": "header",
      "content": "Body"
    },
    {
      "type": "select",
      "id": "body_size",
      "label": "Body text size",
      "info": "Minimum 1rem / 16px. Guarantee strip text scales with this control.",
      "options": [
        { "value": "1",   "label": "Normal (1rem / 16px)" },
        { "value": "1.1", "label": "Comfortable (1.1rem)" },
        { "value": "1.2", "label": "Large (1.2rem)" },
        { "value": "1.3", "label": "X-large (1.3rem)" },
        { "value": "1.5", "label": "Display (1.5rem)" }
      ],
      "default": "1"
    },
    {
      "type": "select",
      "id": "body_max_width",
      "label": "Body container width",
      "options": [
        { "value": "480",  "label": "Narrow (480px)" },
        { "value": "640",  "label": "Medium (640px)" },
        { "value": "800",  "label": "Wide (800px)" },
        { "value": "1000", "label": "Full (1000px)" }
      ],
      "default": "1000"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "icon",
      "label": "Icon/Emoji",
      "default": "🛡",
      "info": "Use an emoji or leave blank"
    },
    {
      "type": "richtext",
      "id": "guarantee_text",
      "label": "Guarantee text",
      "default": "<p><strong>30-day satisfaction guarantee.</strong> If you don't feel a measurable difference, we'll refund you. No questions asked.</p>"
    }
  ],
  "presets": [
    {
      "name": "Igniton Guarantee Strip",
      "settings": {
        "icon": "🛡",
        "guarantee_text": "<p><strong>30-day satisfaction guarantee.</strong> If you don't feel a measurable difference, we'll refund you. No questions asked.</p>"
      }
    }
  ]
}
{% endschema %}
