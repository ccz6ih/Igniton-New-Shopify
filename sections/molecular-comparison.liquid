{{ 'component-molecular-comparison.css' | asset_url | stylesheet_tag }}

{% render 'ig-section-controls', section: section %}

{%- liquid
  assign before_num = section.settings.measurement_before | times: 1.0
  assign after_num  = section.settings.measurement_after  | times: 1.0
  assign delta_raw  = after_num | minus: before_num
  assign delta_pct  = 0
  if before_num > 0
    assign delta_pct = delta_raw | times: 100.0 | divided_by: before_num | round: 1
  endif
-%}

<section
  id="MolecularComparison-{{ section.id }}"
  class="molecular color-{{ section.settings.color_scheme }} molecular--feat-{{ section.settings.feature_cells_layout }}{% if section.settings.show_decorative_overlay %} molecular--overlay{% endif %}"
>
  <div class="molecular__container">
    {%- if section.settings.section_label != blank -%}
      <p class="ig-section-label">{{ section.settings.section_label }}</p>
    {%- endif -%}
    {%- if section.settings.section_heading != blank -%}
      <h2 class="ig-section-title">{{ section.settings.section_heading }}</h2>
    {%- endif -%}

    <div class="molecular__grid">
      <aside class="molecular__measurement color-scheme-2" aria-label="Molecular measurement comparison">
        {%- if section.settings.show_decorative_overlay -%}
          <div class="molecular__overlay" aria-hidden="true"></div>
        {%- endif -%}

        {%- if section.settings.measurement_delta_highlight and delta_pct != 0 -%}
          <div class="molecular__delta" aria-label="Improvement percentage">
            {%- if delta_pct > 0 -%}+{%- endif -%}{{ delta_pct }}%
          </div>
        {%- endif -%}

        <div class="molecular__measurement-inner">
          <div class="molecular__readout">
            <div class="molecular__readout-before">
              <span class="molecular__readout-value">{{ section.settings.measurement_before }}</span>
              {%- if section.settings.measurement_before_label != blank -%}
                <span class="molecular__readout-label">{{ section.settings.measurement_before_label }}</span>
              {%- endif -%}
            </div>
            <div class="molecular__readout-arrow" aria-hidden="true">&rarr;</div>
            <div class="molecular__readout-after">
              <span class="molecular__readout-value">{{ section.settings.measurement_after }}</span>
              {%- if section.settings.measurement_after_label != blank -%}
                <span class="molecular__readout-label">{{ section.settings.measurement_after_label }}</span>
              {%- endif -%}
            </div>
          </div>

          {%- if section.settings.measurement_unit != blank -%}
            <div class="molecular__unit">{{ section.settings.measurement_unit }}</div>
          {%- endif -%}

          {%- if section.settings.measurement_caption != blank -%}
            <div class="molecular__caption">{{ section.settings.measurement_caption }}</div>
          {%- endif -%}
        </div>
      </aside>

      <div class="molecular__features">
        {%- for block in section.blocks -%}
          {%- if block.type == 'feature' -%}
            <div class="molecular__feature" {{ block.shopify_attributes }}>
              {%- if block.settings.icon != blank -%}
                <div class="molecular__feature-icon" aria-hidden="true">{{ block.settings.icon }}</div>
              {%- endif -%}
              <div class="molecular__feature-body">
                {%- if block.settings.title != blank -%}
                  <h3 class="molecular__feature-title">{{ block.settings.title }}</h3>
                {%- endif -%}
                {%- if block.settings.description != blank -%}
                  <p class="molecular__feature-desc ig-section-body">{{ block.settings.description }}</p>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

