{{ 'component-study-cards.css' | asset_url | stylesheet_tag }}

{% render 'ig-section-controls', section: section %}

<section
  id="StudyCards-{{ section.id }}"
  class="study-cards color-{{ section.settings.color_scheme }} study-cards--cols-{{ section.settings.columns_desktop }} study-cards--style-{{ section.settings.card_style }}"
>
  <div class="study-cards__container">
    {%- if section.settings.section_label != blank -%}
      <p class="ig-section-label{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
        {{ section.settings.section_label }}
      </p>
    {%- endif -%}

    {%- if section.settings.section_heading != blank -%}
      <h2 class="ig-section-title ig-font-display{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
        {{ section.settings.section_heading }}
      </h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="study-cards__grid{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
        {%- for block in section.blocks -%}
          {%- if block.type == 'study' -%}
            {%- liquid
              assign resolved_link = ''
              if block.settings.link_article != blank
                assign resolved_link = block.settings.link_article.url
              elsif block.settings.link_url != blank
                assign resolved_link = block.settings.link_url
              endif

              assign link_label_text = block.settings.link_label
              if link_label_text == blank
                assign link_label_text = 'Read study →'
              endif
            -%}

            <article class="study-card" {{ block.shopify_attributes }}>
              {%- if block.settings.tag != blank -%}
                <span class="study-card__tag ig-section-label">{{ block.settings.tag }}</span>
              {%- endif -%}

              {%- if block.settings.title != blank -%}
                <h3 class="study-card__title ig-section-body ig-font-body">{{ block.settings.title }}</h3>
              {%- endif -%}

              {%- if block.settings.authors != blank -%}
                <p class="study-card__authors">{{ block.settings.authors }}</p>
              {%- endif -%}

              {%- if block.settings.design_stat_1_value != blank or block.settings.design_stat_2_value != blank or block.settings.design_stat_3_value != blank -%}
                <div class="study-card__design">
                  {%- if block.settings.design_stat_1_value != blank -%}
                    <div class="study-card__design-cell">
                      <div class="study-card__design-value">{{ block.settings.design_stat_1_value }}</div>
                      {%- if block.settings.design_stat_1_label != blank -%}
                        <div class="study-card__design-label">{{ block.settings.design_stat_1_label }}</div>
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                  {%- if block.settings.design_stat_2_value != blank -%}
                    <div class="study-card__design-cell">
                      <div class="study-card__design-value">{{ block.settings.design_stat_2_value }}</div>
                      {%- if block.settings.design_stat_2_label != blank -%}
                        <div class="study-card__design-label">{{ block.settings.design_stat_2_label }}</div>
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                  {%- if block.settings.design_stat_3_value != blank -%}
                    <div class="study-card__design-cell">
                      <div class="study-card__design-value">{{ block.settings.design_stat_3_value }}</div>
                      {%- if block.settings.design_stat_3_label != blank -%}
                        <div class="study-card__design-label">{{ block.settings.design_stat_3_label }}</div>
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                </div>
              {%- endif -%}

              {%- if block.settings.integrity_markers != blank -%}
                {%- assign marker_lines = block.settings.integrity_markers | newline_to_br | split: '<br />' -%}
                <ul class="study-card__markers">
                  {%- for line in marker_lines -%}
                    {%- assign clean = line | strip -%}
                    {%- if clean != blank -%}
                      <li class="study-card__marker">{{ clean }}</li>
                    {%- endif -%}
                  {%- endfor -%}
                </ul>
              {%- endif -%}

              {%- if resolved_link != blank -%}
                <a href="{{ resolved_link }}" class="study-card__link">{{ link_label_text }}</a>
              {%- endif -%}
            </article>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- else -%}
      <div class="study-cards__placeholder">
        <p>Add study blocks to showcase clinical evidence.</p>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
