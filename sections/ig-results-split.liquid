          }
        },
        {
          "type": "testimonial",
          "settings": {
            "star_rating": 5,
            "quote": "My brain is sharper than it's been in a long time. And my shoulder finally seems to be getting better. This stuff works.",
            "customer_meta": "Verified customer · IgniCognition"
          }
        },
        {
