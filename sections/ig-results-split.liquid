            "customer_meta": "Verified customer · IgniCognition"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "star_rating": 5,
            "quote": "I feel so much sharper and my mind feels so clear after taking this for over two weeks.",
            "customer_meta": "Verified customer · IgniCognition"
          }
        }
      ]
    }
  ]
}
{% endschema %}
