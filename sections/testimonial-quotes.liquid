{{ 'component-testimonial-quotes.css' | asset_url | stylesheet_tag }}

{% render 'ig-section-controls', section: section %}

<section
  id="Testimonials-{{ section.id }}"
  class="testimonials color-{{ section.settings.color_scheme }} testimonials--cols-{{ section.settings.columns_desktop }} testimonials--style-{{ section.settings.quote_style }}"
>
  <div class="testimonials__container">
    {%- if section.settings.section_label != blank -%}
      <p class="ig-section-label">{{ section.settings.section_label }}</p>
    {%- endif -%}
    {%- if section.settings.section_heading != blank -%}
      <h2 class="ig-section-title">{{ section.settings.section_heading }}</h2>
    {%- endif -%}
    {%- if section.blocks.size > 0 -%}
      <div class="testimonials__grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'quote' -%}
            <figure class="testimonial-card" {{ block.shopify_attributes }}>
              {%- if section.settings.show_portraits and block.settings.portrait != blank -%}
                <div class="testimonial-card__portrait testimonial-card__portrait--{{ section.settings.image_ratio }}">
                  {{
                    block.settings.portrait
                    | image_url: width: 240
                    | image_tag:
                      loading: 'lazy',
                      widths: '80,160,240',
                      sizes: '160px',
                      alt: block.settings.portrait.alt | default: block.settings.name
                  }}
                </div>
              {%- endif -%}
              {%- if section.settings.show_stars -%}
                <div
                  class="testimonial-card__stars"
                  aria-label="{{ block.settings.star_rating }} out of 5 stars"
                >
                  {%- for i in (1..5) -%}
                    <span
                      class="testimonial-card__star{% if i <= block.settings.star_rating %} testimonial-card__star--filled{% endif %}"
                      aria-hidden="true"
                    >★</span>
                  {%- endfor -%}
                </div>
              {%- endif -%}
              <blockquote class="testimonial-card__quote ig-section-body">
                {{ block.settings.quote_text }}
              </blockquote>
              <figcaption class="testimonial-card__cite">
                <div class="testimonial-card__name">{{ block.settings.name }}</div>
                {%- if block.settings.credentials != blank -%}
                  <div class="testimonial-card__credentials">{{ block.settings.credentials }}</div>
                {%- endif -%}
                {%- if block.settings.show_verified -%}
                  <div class="testimonial-card__verified">
                    <span class="testimonial-card__verified-check" aria-hidden="true">✓</span>
                    Verified customer
                  </div>
                {%- endif -%}
              </figcaption>
            </figure>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Testimonial Quotes",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Color"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "options": [
        { "value": "narrow",  "label": "Narrow (720px)" },
        { "value": "medium",  "label": "Medium (960px)" },
        { "value": "default", "label": "Default (1200px)" },
        { "value": "wide",    "label": "Wide (1440px)" },
        { "value": "full",    "label": "Full bleed" }
      ],
      "default": "default"
    },
    {
      "type": "header",
      "content": "Spacing — desktop"
    },
    {
      "type": "range",
      "id": "padding_block_start_desktop",
      "min": 0, "max": 200, "step": 4,
      "unit": "px",
      "default": 96,
      "label": "Top padding (desktop)"
    },
    {
      "type": "range",
      "id": "padding_block_end_desktop",
      "min": 0, "max": 200, "step": 4,
      "unit": "px",
      "default": 96,
      "label": "Bottom padding (desktop)"
    },
    {
      "type": "header",
      "content": "Spacing — mobile"
    },
    {
      "type": "range",
      "id": "padding_block_start_mobile",
      "min": 0, "max": 200, "step": 4,
      "unit": "px",
      "default": 48,
      "label": "Top padding (mobile)"
    },
    {
      "type": "range",
      "id": "padding_block_end_mobile",
      "min": 0, "max": 200, "step": 4,
      "unit": "px",
      "default": 48,
      "label": "Bottom padding (mobile)"
    },
    {
      "type": "header",
      "content": "Label"
    },
    {
      "type": "range",
      "id": "label_size",
      "min": 60, "max": 180, "step": 5,
      "unit": "%",
      "default": 100,
      "label": "Label size",
      "info": "Percent of base label size (0.8125rem / 13px)."
    },
    {
      "type": "select",
      "id": "label_spacing",
      "label": "Space below label",
      "options": [
        { "value": "0.25", "label": "Tight" },
        { "value": "0.5",  "label": "Compact" },
        { "value": "0.75", "label": "Normal" },
        { "value": "1.25", "label": "Loose" },
        { "value": "2",    "label": "Spacious" }
      ],
      "default": "0.75"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 2, "max": 6, "step": 0.5,
      "unit": "rem",
      "default": 3,
      "label": "Heading size (desktop)"
    },
    {
      "type": "select",
      "id": "heading_max_width",
      "label": "Heading container width",
      "options": [
        { "value": "600",  "label": "Narrow (600px)" },
        { "value": "900",  "label": "Medium (900px)" },
        { "value": "1200", "label": "Wide (1200px)" },
        { "value": "1400", "label": "Full (1400px)" }
      ],
      "default": "900"
    },
    {
      "type": "select",
      "id": "heading_spacing",
      "label": "Space below heading",
      "options": [
        { "value": "1",    "label": "Tight" },
        { "value": "1.75", "label": "Compact" },
        { "value": "2.5",  "label": "Normal" },
        { "value": "3.5",  "label": "Loose" },
        { "value": "5",    "label": "Spacious" }
      ],
      "default": "2.5"
    },
    {
      "type": "select",
      "id": "mobile_heading_scale",
      "label": "Mobile heading scale",
      "info": "How aggressively the heading shrinks on mobile.",
      "options": [
        { "value": "40",  "label": "Aggressive (40%)" },
        { "value": "55",  "label": "Balanced (55%)" },
        { "value": "65",  "label": "Default (65%)" },
        { "value": "80",  "label": "Gentle (80%)" },
        { "value": "100", "label": "Same as desktop" }
      ],
      "default": "65"
    },
    {
      "type": "header",
      "content": "Body"
    },
    {
      "type": "range",
      "id": "body_size",
      "min": 1, "max": 1.5, "step": 0.1,
      "unit": "rem",
      "default": 1,
      "label": "Body text size",
      "info": "Minimum 1rem / 16px. Legal disclaimers are handled separately."
    },
    {
      "type": "select",
      "id": "body_max_width",
      "label": "Body container width",
      "options": [
        { "value": "480", "label": "Narrow (480px)" },
        { "value": "640", "label": "Medium (640px)" },
        { "value": "800", "label": "Wide (800px)" },
        { "value": "1000","label": "Full (1000px)" }
      ],
      "default": "640"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Portrait aspect ratio",
      "info": "Square renders as a circle; portrait and natural render with rounded corners.",
      "options": [
        { "value": "square",   "label": "Square / circle (1:1)" },
        { "value": "portrait", "label": "Portrait (4:5)" },
        { "value": "natural",  "label": "Natural" }
      ],
      "default": "square"
    },
    {
      "type": "header",
      "content": "Section content"
    },
    {
      "type": "text",
      "id": "section_label",
      "label": "Section label",
      "default": "Testimonials"
    },
    {
      "type": "inline_richtext",
      "id": "section_heading",
      "label": "Section heading",
      "default": "What people are saying."
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columns (desktop)",
      "options": [
        { "value": "1", "label": "1 column" },
        { "value": "2", "label": "2 columns" },
        { "value": "3", "label": "3 columns" }
      ],
      "default": "2"
    },
    {
      "type": "checkbox",
      "id": "show_portraits",
      "label": "Show portraits",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_stars",
      "label": "Show star ratings",
      "default": false
    },
    {
      "type": "select",
      "id": "quote_style",
      "label": "Quote style",
      "info": "Serif large uses Dawn's heading family in italic; sans medium uses the body family.",
      "options": [
        { "value": "serif-large",  "label": "Serif — large italic" },
        { "value": "sans-medium",  "label": "Sans — medium" }
      ],
      "default": "serif-large"
    }
  ],
  "blocks": [
    {
      "type": "quote",
      "name": "Quote",
      "limit": 6,
      "settings": [
        {
          "type": "richtext",
          "id": "quote_text",
          "label": "Quote",
          "default": "<p>This product genuinely changed how clear I feel day-to-day.</p>"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Dr. Sarah Chen"
        },
        {
          "type": "text",
          "id": "credentials",
          "label": "Credentials / title",
          "default": "Neurologist, MD"
        },
        {
          "type": "image_picker",
          "id": "portrait",
          "label": "Portrait (optional)"
        },
        {
          "type": "range",
          "id": "star_rating",
          "min": 1, "max": 5, "step": 1,
          "default": 5,
          "label": "Star rating"
        },
        {
          "type": "checkbox",
          "id": "show_verified",
          "label": "Show \"Verified customer\" badge",
          "default": false
        },
        {
          "type": "product",
          "id": "linked_product",
          "label": "Linked product (optional)",
          "info": "For review cards tied to a specific product."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials — 2 columns (physicians)",
      "settings": {
        "color_scheme": "scheme-2",
        "columns_desktop": "2",
        "show_portraits": true,
        "show_stars": false,
        "quote_style": "serif-large",
        "image_ratio": "square",
        "section_label": "Physician endorsements",
        "section_heading": "Recommended by clinicians who understand the science."
      },
      "blocks": [
        {
          "type": "quote",
          "settings": {
            "quote_text": "<p>The clinical data is the real thing — the kind of evidence I actually trust before recommending a supplement.</p>",
            "name": "Dr. Sarah Chen",
            "credentials": "Neurologist, MD",
            "star_rating": 5,
            "show_verified": false
          }
        },
        {
          "type": "quote",
          "settings": {
            "quote_text": "<p>I've reviewed dozens of cognitive formulas. This is one of the few with both a rigorous trial and a clean label.</p>",
            "name": "Dr. Michael Reyes",
            "credentials": "Integrative Medicine, DO",
            "star_rating": 5,
            "show_verified": false
          }
        }
      ]
    },
    {
      "name": "Testimonials — 3 columns (reviews)",
      "settings": {
        "color_scheme": "scheme-1",
        "columns_desktop": "3",
        "show_portraits": true,
        "show_stars": true,
        "quote_style": "serif-large",
        "image_ratio": "square",
        "section_label": "Customer reviews",
        "section_heading": "Real results from verified customers."
      },
      "blocks": [
        {
          "type": "quote",
          "settings": {
            "quote_text": "<p>My brain is sharper than it's been in a long time. This stuff works.</p>",
            "name": "James P.",
            "credentials": "90 days on product",
            "star_rating": 5,
            "show_verified": true
          }
        },
        {
          "type": "quote",
          "settings": {
            "quote_text": "<p>I'm 71 and I can't believe the difference. My mind feels very sharp.</p>",
            "name": "Margaret L.",
            "credentials": "Verified buyer",
            "star_rating": 5,
            "show_verified": true
          }
        },
        {
          "type": "quote",
          "settings": {
            "quote_text": "<p>Feel so much clearer after two weeks — noticeable focus at work.</p>",
            "name": "Daniel R.",
            "credentials": "Verified buyer",
            "star_rating": 5,
            "show_verified": true
          }
        }
      ]
    }
  ]
}
{% endschema %}
