{{ 'component-ig-how-it-works.css' | asset_url | stylesheet_tag }}

{% render 'ig-section-controls', section: section %}

<section
  id="IgHowItWorks-{{ section.id }}"
  class="ig-how-it-works color-{{ section.settings.color_scheme }}"
>
  <div class="ig-how-it-works__container">
    {%- if section.settings.section_label != blank -%}
      <p class="ig-section-label{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
        {{ section.settings.section_label }}
      </p>
    {%- endif -%}

    {%- if section.settings.section_title != blank -%}
      <h2 class="ig-section-title ig-font-display{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
        {{ section.settings.section_title }}
      </h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="ig-how-it-works__steps{% if section.settings.alternate_steps %} ig-how-it-works__steps--alternating{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'step' -%}
              <div class="ig-how-it-works__step" {{ block.shopify_attributes }}>
                <div class="ig-how-it-works__step-num ig-font-display">
                  {{ block.settings.step_number }}
                </div>
                <div class="ig-how-it-works__step-title ig-section-body ig-font-body">
                  {{ block.settings.step_title }}
                </div>
                <div class="ig-how-it-works__step-desc ig-section-body ig-font-body">
                  {{ block.settings.step_description }}
                </div>
              </div>
          {%- endcase -%}
        {%- endfor -%}
      </div>

      {%- if section.settings.footer_link_text != blank -%}
        <div class="ig-how-it-works__footer{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
          <a
            href="{{ section.settings.footer_link_url }}"
            class="ig-how-it-works__link ig-section-body"
          >
            {{ section.settings.footer_link_text }}
          </a>
        </div>
      {%- endif -%}
    {%- else -%}
      <div class="ig-how-it-works__placeholder">
        <p>Add step blocks to explain your process.</p>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Igniton How It Works",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Color"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "options": [
        { "value": "narrow",  "label": "Narrow (720px)" },
        { "value": "medium",  "label": "Medium (960px)" },
        { "value": "default", "label": "Default (1200px)" },
        { "value": "wide",    "label": "Wide (1440px)" },
        { "value": "full",    "label": "Full bleed" }
      ],
      "default": "default"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "section_label",
      "default": "How it works",
      "label": "Section label"
    },
    {
      "type": "inline_richtext",
      "id": "section_title",
      "default": "Good ingredients aren't enough. They have to work.",
      "label": "Section title"
    },
    {
      "type": "header",
      "content": "Spacing — desktop"
    },
    {
      "type": "range",
      "id": "padding_block_start_desktop",
      "min": 0, "max": 200, "step": 4,
      "unit": "px",
      "default": 96,
      "label": "Top padding (desktop)"
    },
    {
      "type": "range",
      "id": "padding_block_end_desktop",
      "min": 0, "max": 200, "step": 4,
      "unit": "px",
      "default": 96,
      "label": "Bottom padding (desktop)"
    },
    {
      "type": "header",
      "content": "Spacing — mobile"
    },
    {
      "type": "range",
      "id": "padding_block_start_mobile",
      "min": 0, "max": 200, "step": 4,
      "unit": "px",
      "default": 48,
      "label": "Top padding (mobile)"
    },
    {
      "type": "range",
      "id": "padding_block_end_mobile",
      "min": 0, "max": 200, "step": 4,
      "unit": "px",
      "default": 48,
      "label": "Bottom padding (mobile)"
    },
    {
      "type": "header",
      "content": "Label"
    },
    {
      "type": "range",
      "id": "label_size",
      "min": 60, "max": 180, "step": 5,
      "unit": "%",
      "default": 100,
      "label": "Label size",
      "info": "Percent of base label size (0.8125rem / 13px)."
    },
    {
      "type": "select",
      "id": "label_spacing",
      "label": "Space below label",
      "options": [
        { "value": "0.25", "label": "Tight" },
        { "value": "0.5",  "label": "Compact" },
        { "value": "0.75", "label": "Normal" },
        { "value": "1.25", "label": "Loose" },
        { "value": "2",    "label": "Spacious" }
      ],
      "default": "0.75"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 2, "max": 14, "step": 0.5,
      "unit": "rem",
      "default": 3,
      "label": "Heading size (desktop)"
    },
    {
      "type": "select",
      "id": "heading_max_width",
      "label": "Heading container width",
      "options": [
        { "value": "600",  "label": "Narrow (600px)" },
        { "value": "900",  "label": "Medium (900px)" },
        { "value": "1200", "label": "Wide (1200px)" },
        { "value": "1400", "label": "Full (1400px)" }
      ],
      "default": "900"
    },
    {
      "type": "select",
      "id": "heading_spacing",
      "label": "Space below heading",
      "options": [
        { "value": "1",    "label": "Tight" },
        { "value": "1.75", "label": "Compact" },
        { "value": "2.5",  "label": "Normal" },
        { "value": "3.5",  "label": "Loose" },
        { "value": "5",    "label": "Spacious" }
      ],
      "default": "2.5"
    },
    {
      "type": "range",
      "id": "mobile_heading_scale",
      "min": 40, "max": 100, "step": 5,
      "unit": "%",
      "default": 65,
      "label": "Mobile heading scale",
      "info": "How aggressively the heading shrinks on mobile (as a % of desktop size)."
    },
    {
      "type": "header",
      "content": "Body"
    },
    {
      "type": "range",
      "id": "body_size",
      "min": 1, "max": 1.5, "step": 0.1,
      "unit": "rem",
      "default": 1,
      "label": "Body text size",
      "info": "Minimum 1rem / 16px. Legal disclaimers are handled separately."
    },
    {
      "type": "select",
      "id": "body_max_width",
      "label": "Body container width",
      "options": [
        { "value": "480", "label": "Narrow (480px)" },
        { "value": "640", "label": "Medium (640px)" },
        { "value": "800", "label": "Wide (800px)" },
        { "value": "1000","label": "Full (1000px)" }
      ],
      "default": "640"
    },
    {
      "type": "header",
      "content": "Steps — styling"
    },
    {
      "type": "checkbox",
      "id": "alternate_steps",
      "label": "Alternate step colors",
      "default": false,
      "info": "Inverts colors on every other step for a rhythmic reading cadence. Works on all color schemes."
    },
    {
      "type": "header",
      "content": "Footer link"
    },
    {
      "type": "text",
      "id": "footer_link_text",
      "label": "Link text",
      "default": "Read the full clinical studies →"
    },
    {
      "type": "url",
      "id": "footer_link_url",
      "label": "Link URL"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "limit": 8,
      "settings": [
        {
          "type": "text",
          "id": "step_number",
          "default": "01",
          "label": "Step number",
          "info": "e.g., 01, 02, 03"
        },
        {
          "type": "text",
          "id": "step_title",
          "default": "Gold-standard ingredients",
          "label": "Step title"
        },
        {
          "type": "textarea",
          "id": "step_description",
          "default": "Every compound selected based on clinical evidence — Citicoline, Alpha-GPC, NMN, Resveratrol, CoQ10. No fillers. No excipients.",
          "label": "Step description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Igniton How It Works",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "step_number": "01",
            "step_title": "Gold-standard ingredients",
            "step_description": "Every compound selected based on clinical evidence — Citicoline, Alpha-GPC, NMN, Resveratrol, CoQ10. No fillers. No excipients."
          }
        },
        {
          "type": "step",
          "settings": {
            "step_number": "02",
            "step_title": "Enhanced with cold plasma",
            "step_description": "Ingredients are processed through a proprietary cold plasma and laser-photonics system developed over 30 years of advanced physics research."
          }
        },
        {
          "type": "step",
          "settings": {
            "step_number": "03",
            "step_title": "Greater bioavailability",
            "step_description": "The enhancement process increases cellular uptake — so more of what you take actually reaches the cells that need it."
          }
        },
        {
          "type": "step",
          "settings": {
            "step_number": "04",
            "step_title": "Measurable results",
            "step_description": "University-led trials showed statistically significant improvements over the same unenhanced formula — proven to work better, not just different."
          }
        }
      ]
    }
  ]
}
{% endschema %}
