{{ 'component-ig-why-different.css' | asset_url | stylesheet_tag }}

{% render 'ig-section-controls', section: section %}

<section
  id="IgWhyDifferent-{{ section.id }}"
  class="ig-why-different color-{{ section.settings.color_scheme }}"
>
  <div class="ig-why-different__container">
    {%- if section.settings.section_label != blank -%}
      <p class="ig-section-label{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
        {{ section.settings.section_label }}
      </p>
    {%- endif -%}

    {%- if section.settings.section_title != blank -%}
      <h2 class="ig-section-title ig-font-display{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
        {{ section.settings.section_title }}
      </h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="ig-why-different__grid{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'feature_card' -%}
              <div class="ig-why-different__card" {{ block.shopify_attributes }}>
                {%- if block.settings.icon_svg != blank or block.settings.icon_emoji != blank -%}
                  <div class="ig-why-different__icon">
                    {%- if block.settings.icon_emoji != blank -%}
                      <span class="ig-why-different__icon-emoji">{{ block.settings.icon_emoji }}</span>
                    {%- elsif block.settings.icon_svg != blank -%}
                      {{ block.settings.icon_svg }}
                    {%- endif -%}
                  </div>
                {%- endif -%}

                <div class="ig-why-different__title ig-section-body ig-font-body">
                  {{ block.settings.title }}
                </div>

                <div class="ig-why-different__desc ig-section-body ig-font-body">
                  {{ block.settings.description }}
                </div>
              </div>
          {%- endcase -%}
        {%- endfor -%}
      </div>
    {%- else -%}
      <div class="ig-why-different__placeholder">
        <p>Add feature cards to highlight what makes you different.</p>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Igniton Why Different",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Color"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "options": [
        { "value": "narrow",  "label": "Narrow (720px)" },
        { "value": "medium",  "label": "Medium (960px)" },
        { "value": "default", "label": "Default (1200px)" },
        { "value": "wide",    "label": "Wide (1440px)" },
        { "value": "full",    "label": "Full bleed" }
      ],
      "default": "default"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "section_label",
      "default": "Why Igniton is different",
      "label": "Section label"
    },
    {
      "type": "inline_richtext",
      "id": "section_title",
      "default": "Not just what's in it. What's been done to it.",
      "label": "Section title"
    },
    {
      "type": "header",
      "content": "Spacing — desktop"
    },
    {
      "type": "range",
      "id": "padding_block_start_desktop",
      "min": 0, "max": 200, "step": 4,
      "unit": "px",
      "default": 96,
      "label": "Top padding (desktop)"
    },
    {
      "type": "range",
      "id": "padding_block_end_desktop",
      "min": 0, "max": 200, "step": 4,
      "unit": "px",
      "default": 96,
      "label": "Bottom padding (desktop)"
    },
    {
      "type": "header",
      "content": "Spacing — mobile"
    },
    {
      "type": "range",
      "id": "padding_block_start_mobile",
      "min": 0, "max": 200, "step": 4,
      "unit": "px",
      "default": 48,
      "label": "Top padding (mobile)"
    },
    {
      "type": "range",
      "id": "padding_block_end_mobile",
      "min": 0, "max": 200, "step": 4,
      "unit": "px",
      "default": 48,
      "label": "Bottom padding (mobile)"
    },
    {
      "type": "header",
      "content": "Label"
    },
    {
      "type": "select",
      "id": "label_size",
      "label": "Label size",
      "info": "Percent of base label size (0.8125rem / 13px).",
      "options": [
        { "value": "70",  "label": "XS (70%)" },
        { "value": "85",  "label": "Small (85%)" },
        { "value": "100", "label": "Default (100%)" },
        { "value": "120", "label": "Large (120%)" },
        { "value": "150", "label": "XL (150%)" }
      ],
      "default": "100"
    },
    {
      "type": "select",
      "id": "label_spacing",
      "label": "Space below label",
      "options": [
        { "value": "0.25", "label": "Tight" },
        { "value": "0.5",  "label": "Compact" },
        { "value": "0.75", "label": "Normal" },
        { "value": "1.25", "label": "Loose" },
        { "value": "2",    "label": "Spacious" }
      ],
      "default": "0.75"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 2, "max": 8, "step": 0.5,
      "unit": "rem",
      "default": 3,
      "label": "Heading size (desktop)"
    },
    {
      "type": "select",
      "id": "heading_max_width",
      "label": "Heading container width",
      "options": [
        { "value": "600",  "label": "Narrow (600px)" },
        { "value": "900",  "label": "Medium (900px)" },
        { "value": "1200", "label": "Wide (1200px)" },
        { "value": "1400", "label": "Full (1400px)" }
      ],
      "default": "900"
    },
    {
      "type": "select",
      "id": "heading_spacing",
      "label": "Space below heading",
      "options": [
        { "value": "1",    "label": "Tight" },
        { "value": "1.75", "label": "Compact" },
        { "value": "2.5",  "label": "Normal" },
        { "value": "3.5",  "label": "Loose" },
        { "value": "5",    "label": "Spacious" }
      ],
      "default": "2.5"
    },
    {
      "type": "select",
      "id": "mobile_heading_scale",
      "label": "Mobile heading scale",
      "info": "How aggressively the heading shrinks on mobile.",
      "options": [
        { "value": "40",  "label": "Aggressive (40%)" },
        { "value": "55",  "label": "Balanced (55%)" },
        { "value": "65",  "label": "Default (65%)" },
        { "value": "80",  "label": "Gentle (80%)" },
        { "value": "100", "label": "Same as desktop" }
      ],
      "default": "65"
    },
    {
      "type": "header",
      "content": "Body"
    },
    {
      "type": "range",
      "id": "body_size",
      "min": 1, "max": 1.5, "step": 0.1,
      "unit": "rem",
      "default": 1,
      "label": "Body text size",
      "info": "Minimum 1rem / 16px. Legal disclaimers are handled separately."
    },
    {
      "type": "select",
      "id": "body_max_width",
      "label": "Body container width",
      "options": [
        { "value": "480", "label": "Narrow (480px)" },
        { "value": "640", "label": "Medium (640px)" },
        { "value": "800", "label": "Wide (800px)" },
        { "value": "1000","label": "Full (1000px)" }
      ],
      "default": "640"
    }
  ],
  "blocks": [
    {
      "type": "feature_card",
      "name": "Feature Card",
      "limit": 8,
      "settings": [
        {
          "type": "text",
          "id": "icon_emoji",
          "label": "Icon emoji",
          "info": "Use an emoji (e.g., ✓, 🔬, ⚡). Leave blank if using SVG."
        },
        {
          "type": "html",
          "id": "icon_svg",
          "label": "Icon SVG code",
          "info": "Paste SVG code here. Leave blank if using emoji."
        },
        {
          "type": "text",
          "id": "title",
          "default": "No fillers. Ever.",
          "label": "Feature title"
        },
        {
          "type": "textarea",
          "id": "description",
          "default": "Every capsule contains only active ingredients — no excipients, no flow agents, no bulking compounds. Pure, dense nutrition.",
          "label": "Feature description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Igniton Why Different",
      "blocks": [
        {
          "type": "feature_card",
          "settings": {
            "icon_svg": "<svg viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z\"/></svg>",
            "title": "No fillers. Ever.",
            "description": "Every capsule contains only active ingredients — no excipients, no flow agents, no bulking compounds. Pure, dense nutrition."
          }
        },
        {
          "type": "feature_card",
          "settings": {
            "icon_svg": "<svg viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z\"/></svg>",
            "title": "Enhanced, not just formulated",
            "description": "Ingredients are processed using cold plasma and laser-photonics technology — a process shown to increase bioavailability at the cellular level."
          }
        },
        {
          "type": "feature_card",
          "settings": {
            "icon_svg": "<svg viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2\"/></svg>",
            "title": "University-tested, not just claimed",
            "description": "Results come from peer-reviewed, randomized controlled trials published in academic journals — not from internal marketing metrics."
          }
        },
        {
          "type": "feature_card",
          "settings": {
            "icon_svg": "<svg viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M13 10V3L4 14h7v7l9-11h-7z\"/></svg>",
            "title": "No stimulants. No crash.",
            "description": "Cognitive benefits come from enhanced cellular function, not caffeine or synthetic stimulants. Sustained energy without the inevitable afternoon drop."
          }
        }
      ]
    }
  ]
}
{% endschema %}
