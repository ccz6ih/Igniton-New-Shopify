{{ 'component-ig-products-showcase.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #IgProductsShowcase-{{ section.id }} .ig-products-showcase__title {
    font-size: calc(var(--font-heading-scale) * {{ section.settings.heading_size }}rem);
  }
  
  #IgProductsShowcase-{{ section.id }} .ig-products-showcase__card {
    font-size: calc(1rem * {{ section.settings.text_size | divided_by: 100.0 }});
  }
{%- endstyle -%}

<section 
  id="IgProductsShowcase-{{ section.id }}" 
  class="ig-products-showcase color-{{ section.settings.color_scheme }}"
>
  <div class="page-width">
    {%- if section.settings.eyebrow != blank -%}
      <p class="ig-section-label">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    
    {%- if section.settings.heading != blank -%}
      <h2 class="ig-products-showcase__title ig-section-title ig-font-display">
        {{ section.settings.heading }}
      </h2>
    {%- endif -%}
    
    <div class="ig-products-showcase__layout">
      <div class="ig-products-showcase__grid">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            
            {%- when 'product_card' -%}
              <a 
                href="{{ block.settings.link }}" 
                class="ig-products-showcase__card{% if block.settings.featured %} ig-products-showcase__card--featured{% endif %}{% if forloop.first %} is-active{% endif %}"
                {{ block.shopify_attributes }}
                data-product-image="{% if block.settings.product_image %}{{ block.settings.product_image | image_url: width: 1200 }}{% endif %}"
                data-product-id="{{ block.id }}"
                {% if block.settings.featured %}style="grid-column: 1 / -1; background: {{ block.settings.featured_bg }};"{% endif %}
              >
              {%- if block.settings.tag != blank -%}
                <p class="ig-products-showcase__tag">{{ block.settings.tag }}</p>
              {%- endif -%}
              
              {%- if block.settings.product_name != blank -%}
                <h3 class="ig-products-showcase__name ig-font-display">
                  {{ block.settings.product_name }}
                </h3>
              {%- endif -%}
              
              {%- if block.settings.description != blank -%}
                <div class="ig-products-showcase__desc ig-font-body">
                  {{ block.settings.description }}
                </div>
              {%- endif -%}
              
              {%- if block.settings.show_stats -%}
                <div class="ig-products-showcase__stats{% if block.settings.featured %} ig-products-showcase__stats--featured{% endif %}">
                  {%- for i in (1..3) -%}
                    {%- assign stat_num_key = 'stat_' | append: i | append: '_num' -%}
                    {%- assign stat_label_key = 'stat_' | append: i | append: '_label' -%}
                    {%- assign stat_num = block.settings[stat_num_key] -%}
                    {%- assign stat_label = block.settings[stat_label_key] -%}
                    
                    {%- if stat_num != blank -%}
                      <div class="ig-products-showcase__stat">
                        <span class="ig-products-showcase__stat-num">{{ stat_num }}</span>
                        <span class="ig-products-showcase__stat-label">{{ stat_label }}</span>
                      </div>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              {%- endif -%}
              
              {%- if block.settings.price_text != blank -%}
                <p class="ig-products-showcase__price">{{ block.settings.price_text }}</p>
              {%- endif -%}
              
              {%- if block.settings.link_text != blank -%}
                <span class="ig-products-showcase__link">
                  {{ block.settings.link_text }} <span>→</span>
                </span>
              {%- endif -%}
            </a>
          
        {%- endcase -%}
      {%- endfor -%}
      </div>
      
      <div class="ig-products-showcase__image-display">
        {%- for block in section.blocks -%}
          {%- if block.type == 'product_card' and block.settings.product_image != blank -%}
            <div 
              class="ig-products-showcase__image{% if forloop.first %} is-active{% endif %}"
              data-product-id="{{ block.id }}"
            >
              {{ block.settings.product_image | image_url: width: 1200 | image_tag: loading: 'lazy', class: 'ig-products-showcase__img' }}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

<script>
(function() {
  const showcaseSection = document.querySelector('#IgProductsShowcase-{{ section.id }}');
  if (!showcaseSection) return;
  
  const cards = showcaseSection.querySelectorAll('.ig-products-showcase__card:not(.ig-products-showcase__card--featured)');
  const images = showcaseSection.querySelectorAll('.ig-products-showcase__image');
  
  cards.forEach(card => {
    card.addEventListener('mouseenter', () => {
      const productId = card.dataset.productId;
      
      // Remove active class from all cards and images
      cards.forEach(c => c.classList.remove('is-active'));
      images.forEach(img => img.classList.remove('is-active'));
      
      // Add active class to current card and matching image
      card.classList.add('is-active');
      const matchingImage = showcaseSection.querySelector(`.ig-products-showcase__image[data-product-id="${productId}"]`);
      if (matchingImage) {
        matchingImage.classList.add('is-active');
      }
    });
  });
})();
</script>

