{{ 'component-ig-products-showcase.css' | asset_url | stylesheet_tag }}

{% render 'ig-section-controls', section: section %}

<section
  id="IgProductsShowcase-{{ section.id }}"
  class="ig-products-showcase color-{{ section.settings.color_scheme }}"
>
  <div class="ig-products-showcase__container">
    {%- if section.settings.eyebrow != blank -%}
      <p class="ig-section-label">{{ section.settings.eyebrow }}</p>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h2 class="ig-products-showcase__title ig-section-title ig-font-display">
        {{ section.settings.heading }}
      </h2>
    {%- endif -%}

    {%- liquid
      assign has_product_images = false
      for block in section.blocks
        if block.type == 'product_card' and block.settings.featured != true
          if block.settings.product and block.settings.product.featured_image
            assign has_product_images = true
            break
          endif
        endif
      endfor

      assign layout_modifier = 'ig-products-showcase__layout--no-images'
      if has_product_images
        assign layout_modifier = 'ig-products-showcase__layout--with-images'
      endif
    -%}

    <div class="ig-products-showcase__layout {{ layout_modifier }}">
      <div class="ig-products-showcase__grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'product_card' and block.settings.featured != true -%}
            {%- liquid
              assign product = block.settings.product
              assign product_url = block.settings.custom_link
              if product != blank
                assign product_url = product.url
              endif
            -%}

            <div
              class="ig-products-showcase__card{% if forloop.first %} is-active{% endif %}"
              {{ block.shopify_attributes }}
              data-product-id="{{ block.id }}"
              data-product-image="{% if product.featured_image %}{{ product.featured_image | image_url: width: 1200 }}{% endif %}"
            >
              {%- if block.settings.tag != blank -%}
                <p class="ig-products-showcase__tag">{{ block.settings.tag }}</p>
              {%- endif -%}

              <h3 class="ig-products-showcase__name ig-font-display">
                {%- if block.settings.custom_name != blank -%}
                  {{ block.settings.custom_name }}
                {%- elsif product != blank -%}
                  {{ product.title }}
                {%- else -%}
                  Product name
                {%- endif -%}
              </h3>

              {%- if block.settings.custom_description != blank or product.description != blank -%}
                <div class="ig-products-showcase__desc ig-section-body ig-font-body">
                  {%- if block.settings.custom_description != blank -%}
                    {{ block.settings.custom_description }}
                  {%- elsif product != blank -%}
                    {{ product.description | strip_html | truncatewords: 30 }}
                  {%- endif -%}
                </div>
              {%- endif -%}

              {%- if block.settings.show_stats -%}
                <div class="ig-products-showcase__stats">
                  {%- for i in (1..3) -%}
                    {%- assign stat_num_key = 'stat_' | append: i | append: '_num' -%}
                    {%- assign stat_label_key = 'stat_' | append: i | append: '_label' -%}
                    {%- assign stat_num = block.settings[stat_num_key] -%}
                    {%- assign stat_label = block.settings[stat_label_key] -%}

                    {%- if stat_num != blank -%}
                      <div class="ig-products-showcase__stat">
                        <span class="ig-products-showcase__stat-num">{{ stat_num }}</span>
                        <span class="ig-products-showcase__stat-label">{{ stat_label }}</span>
                      </div>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              {%- endif -%}

              {%- if block.settings.show_price and product != blank -%}
                <p class="ig-products-showcase__price">
                  From <strong>{{ product.price | money }}</strong>
                  {%- if block.settings.price_note != blank -%}
                    · {{ block.settings.price_note }}
                  {%- endif -%}
                </p>
              {%- endif -%}

              {%- if block.settings.link_text != blank -%}
                <a
                  href="{{ product_url }}"
                  class="button{% if block.settings.button_style_secondary %} button--secondary{% else %} button--primary{% endif %}"
                >
                  {{ block.settings.link_text }}
                </a>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- if has_product_images -%}
        <div class="ig-products-showcase__image-display">
          {%- assign first_non_featured = true -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'product_card' and block.settings.featured != true -%}
              {%- liquid
                assign product = block.settings.product
                assign product_image = product.featured_image
              -%}

              {%- if product_image != blank -%}
                <div
                  class="ig-products-showcase__image{% if first_non_featured %} is-active{% endif %}"
                  data-product-id="{{ block.id }}"
                >
                  {{ product_image | image_url: width: 1200 | image_tag: loading: 'lazy', class: 'ig-products-showcase__img', alt: product.title }}
                </div>
                {%- assign first_non_featured = false -%}
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} Featured Bundle Card (Full Width Below) {%- endcomment -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'product_card' and block.settings.featured == true -%}
        {%- liquid
          assign product = block.settings.product
          assign product_url = block.settings.custom_link
          if product != blank
            assign product_url = product.url
          endif
        -%}

        <div
          class="ig-products-showcase__card ig-products-showcase__card--featured"
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.tag != blank -%}
            <p class="ig-products-showcase__tag">{{ block.settings.tag }}</p>
          {%- endif -%}

          <h3 class="ig-products-showcase__name ig-font-display">
            {%- if block.settings.custom_name != blank -%}
              {{ block.settings.custom_name }}
            {%- elsif product != blank -%}
              {{ product.title }}
            {%- else -%}
              Product name
            {%- endif -%}
          </h3>

          {%- if block.settings.custom_description != blank or product.description != blank -%}
            <div class="ig-products-showcase__desc ig-section-body ig-font-body">
              {%- if block.settings.custom_description != blank -%}
                {{ block.settings.custom_description }}
              {%- elsif product != blank -%}
                {{ product.description | strip_html | truncatewords: 30 }}
              {%- endif -%}
            </div>
          {%- endif -%}

          {%- if block.settings.show_stats -%}
            <div class="ig-products-showcase__stats ig-products-showcase__stats--featured">
              {%- for i in (1..3) -%}
                {%- assign stat_num_key = 'stat_' | append: i | append: '_num' -%}
                {%- assign stat_label_key = 'stat_' | append: i | append: '_label' -%}
                {%- assign stat_num = block.settings[stat_num_key] -%}
                {%- assign stat_label = block.settings[stat_label_key] -%}

                {%- if stat_num != blank -%}
                  <div class="ig-products-showcase__stat">
                    <span class="ig-products-showcase__stat-num">{{ stat_num }}</span>
                    <span class="ig-products-showcase__stat-label">{{ stat_label }}</span>
                  </div>
                {%- endif -%}
              {%- endfor -%}
            </div>
          {%- endif -%}

          {%- if block.settings.show_price and product != blank -%}
            <p class="ig-products-showcase__price">
              From <strong>{{ product.price | money }}</strong>
              {%- if block.settings.price_note != blank -%}
                · {{ block.settings.price_note }}
              {%- endif -%}
            </p>
          {%- endif -%}

          {%- if block.settings.link_text != blank -%}
            <a
              href="{{ product_url }}"
              class="button{% if block.settings.button_style_secondary %} button--secondary{% else %} button--primary{% endif %}"
            >
              {{ block.settings.link_text }}
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>

<script>
(function() {
  const showcaseSection = document.querySelector('#IgProductsShowcase-{{ section.id }}');
  if (!showcaseSection) return;

  const cards = showcaseSection.querySelectorAll('.ig-products-showcase__card:not(.ig-products-showcase__card--featured)');
  const images = showcaseSection.querySelectorAll('.ig-products-showcase__image');

  cards.forEach(card => {
    card.addEventListener('mouseenter', () => {
      const productId = card.dataset.productId;

      // Remove active class from all cards and images
      cards.forEach(c => c.classList.remove('is-active'));
      images.forEach(img => img.classList.remove('is-active'));

      // Add active class to current card and matching image
      card.classList.add('is-active');
      const matchingImage = showcaseSection.querySelector(`.ig-products-showcase__image[data-product-id="${productId}"]`);
      if (matchingImage) {
        matchingImage.classList.add('is-active');
      }
    });
  });
})();
</script>

