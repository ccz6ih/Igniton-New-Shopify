{{ 'component-ig-final-cta.css' | asset_url | stylesheet_tag }}

{% render 'ig-section-controls', section: section %}

<section
  id="IgFinalCta-{{ section.id }}"
  class="ig-final-cta color-{{ section.settings.color_scheme }}{% if section.settings.enable_gradient %} ig-final-cta--gradient{% endif %}"
>
  <div class="ig-final-cta__container">
    <div class="ig-final-cta__content">
      {%- if section.settings.section_label != blank -%}
        <p class="ig-section-label{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
          {{ section.settings.section_label }}
        </p>
      {%- endif -%}

      {%- if section.settings.section_title != blank -%}
        <h2 class="ig-section-title ig-font-display{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
          {{ section.settings.section_title }}
        </h2>
      {%- endif -%}

      {%- if section.settings.subtitle_text != blank -%}
        <div class="ig-final-cta__subtitle ig-section-body ig-font-body{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
          {{ section.settings.subtitle_text }}
        </div>
      {%- endif -%}

      {%- assign button_blocks = section.blocks | where: "type", "button" -%}
      {%- if button_blocks.size > 0 -%}
        <div class="ig-final-cta__buttons{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
          {%- for block in button_blocks -%}
            {%- case block.settings.button_style -%}
              {%- when 'primary' -%}
                {%- assign btn_class = 'button button--primary' -%}
              {%- when 'secondary' -%}
                {%- assign btn_class = 'button button--secondary' -%}
              {%- when 'muted' -%}
                {%- assign btn_class = 'button ig-final-cta__btn--muted' -%}
              {%- else -%}
                {%- assign btn_class = 'button button--primary' -%}
            {%- endcase -%}
            <a
              href="{{ block.settings.button_link | default: '#' }}"
              class="{{ btn_class }}"
              {{ block.shopify_attributes }}
            >
              {{ block.settings.button_label }}
            </a>
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- if section.settings.footer_text != blank -%}
        <div class="ig-final-cta__footer ig-font-body{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
          {{ section.settings.footer_text }}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Igniton Final CTA",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Color"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "options": [
        { "value": "narrow",  "label": "Narrow (720px)" },
        { "value": "medium",  "label": "Medium (960px)" },
        { "value": "default", "label": "Default (1200px)" },
        { "value": "wide",    "label": "Wide (1440px)" },
        { "value": "full",    "label": "Full bleed" }
      ],
      "default": "default"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "section_label",
      "default": "Ready to start",
      "label": "Section label"
    },
    {
      "type": "inline_richtext",
      "id": "section_title",
      "default": "Most customers feel the difference within two weeks.",
      "label": "Section title"
    },
    {
      "type": "richtext",
      "id": "subtitle_text",
      "label": "Subtitle text",
      "default": "<p>Backed by a 30-day guarantee. Subscribe and save 20%.</p>"
    },
    {
      "type": "header",
      "content": "Spacing — desktop"
    },
    {
      "type": "range",
      "id": "padding_block_start_desktop",
      "min": 0, "max": 200, "step": 4,
      "unit": "px",
      "default": 120,
      "label": "Top padding (desktop)"
    },
    {
      "type": "range",
      "id": "padding_block_end_desktop",
      "min": 0, "max": 200, "step": 4,
      "unit": "px",
      "default": 120,
      "label": "Bottom padding (desktop)"
    },
    {
      "type": "header",
      "content": "Spacing — mobile"
    },
    {
      "type": "range",
      "id": "padding_block_start_mobile",
      "min": 0, "max": 200, "step": 4,
      "unit": "px",
      "default": 64,
      "label": "Top padding (mobile)"
    },
    {
      "type": "range",
      "id": "padding_block_end_mobile",
      "min": 0, "max": 200, "step": 4,
      "unit": "px",
      "default": 64,
      "label": "Bottom padding (mobile)"
    },
    {
      "type": "header",
      "content": "Label"
    },
    {
      "type": "select",
      "id": "label_size",
      "label": "Label size",
      "info": "Percent of base label size (0.8125rem / 13px).",
      "options": [
        { "value": "70",  "label": "X-small (70%)" },
        { "value": "85",  "label": "Small (85%)" },
        { "value": "100", "label": "Normal (100%)" },
        { "value": "120", "label": "Large (120%)" },
        { "value": "150", "label": "X-large (150%)" }
      ],
      "default": "100"
    },
    {
      "type": "select",
      "id": "label_spacing",
      "label": "Space below label",
      "options": [
        { "value": "0.25", "label": "Tight" },
        { "value": "0.5",  "label": "Compact" },
        { "value": "0.75", "label": "Normal" },
        { "value": "1.25", "label": "Loose" },
        { "value": "2",    "label": "Spacious" }
      ],
      "default": "0.75"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 2, "max": 8, "step": 0.5,
      "unit": "rem",
      "default": 3,
      "label": "Heading size (desktop)"
    },
    {
      "type": "select",
      "id": "heading_max_width",
      "label": "Heading container width",
      "options": [
        { "value": "600",  "label": "Narrow (600px)" },
        { "value": "900",  "label": "Medium (900px)" },
        { "value": "1200", "label": "Wide (1200px)" },
        { "value": "1400", "label": "Full (1400px)" }
      ],
      "default": "600"
    },
    {
      "type": "select",
      "id": "heading_spacing",
      "label": "Space below heading",
      "options": [
        { "value": "1",    "label": "Tight" },
        { "value": "1.75", "label": "Compact" },
        { "value": "2.5",  "label": "Normal" },
        { "value": "3.5",  "label": "Loose" },
        { "value": "5",    "label": "Spacious" }
      ],
      "default": "1.75"
    },
    {
      "type": "select",
      "id": "mobile_heading_scale",
      "label": "Mobile heading scale",
      "info": "How aggressively the heading shrinks on mobile.",
      "options": [
        { "value": "40",  "label": "Aggressive (40%)" },
        { "value": "55",  "label": "Balanced (55%)" },
        { "value": "65",  "label": "Default (65%)" },
        { "value": "80",  "label": "Gentle (80%)" },
        { "value": "100", "label": "Same as desktop" }
      ],
      "default": "65"
    },
    {
      "type": "header",
      "content": "Body"
    },
    {
      "type": "select",
      "id": "body_size",
      "label": "Body text size",
      "info": "Minimum 1rem / 16px. Legal disclaimers are handled separately.",
      "options": [
        { "value": "1",   "label": "Normal (1rem / 16px)" },
        { "value": "1.1", "label": "Comfortable (1.1rem)" },
        { "value": "1.2", "label": "Large (1.2rem)" },
        { "value": "1.3", "label": "X-large (1.3rem)" },
        { "value": "1.5", "label": "Display (1.5rem)" }
      ],
      "default": "1.1"
    },
    {
      "type": "select",
      "id": "body_max_width",
      "label": "Body container width",
      "options": [
        { "value": "480", "label": "Narrow (480px)" },
        { "value": "640", "label": "Medium (640px)" },
        { "value": "800", "label": "Wide (800px)" },
        { "value": "1000","label": "Full (1000px)" }
      ],
      "default": "640"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "checkbox",
      "id": "enable_gradient",
      "default": true,
      "label": "Enable radial gradient background",
      "info": "Subtle ember gradient effect behind the content."
    },
    {
      "type": "header",
      "content": "Footer text"
    },
    {
      "type": "richtext",
      "id": "footer_text",
      "label": "Footer text",
      "default": "<p>Questions? <a href=\"#\">Read the FAQ</a> or <a href=\"#\">contact us</a>.</p>"
    }
  ],
  "blocks": [
    {
      "type": "button",
      "name": "Button",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "button_label",
          "default": "Shop IgniCognition",
          "label": "Button label"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        },
        {
          "type": "select",
          "id": "button_style",
          "options": [
            {
              "value": "primary",
              "label": "Primary (solid)"
            },
            {
              "value": "secondary",
              "label": "Secondary (outline)"
            },
            {
              "value": "muted",
              "label": "Muted (link)"
            }
          ],
          "default": "primary",
          "label": "Button style"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Igniton Final CTA",
      "blocks": [
        {
          "type": "button",
          "settings": {
            "button_label": "Shop IgniCognition",
            "button_style": "primary"
          }
        },
        {
          "type": "button",
          "settings": {
            "button_label": "Shop IgniLongevity",
            "button_style": "muted"
          }
        }
      ]
    }
  ]
}
{% endschema %}
