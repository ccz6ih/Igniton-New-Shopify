{{ 'component-review-summary.css' | asset_url | stylesheet_tag }}

{% render 'ig-section-controls', section: section %}

{%- liquid
  assign agg_rating_raw = section.settings.aggregate_rating | default: '0'
  assign agg_max_raw = section.settings.aggregate_rating_out_of | default: '5'
  assign agg_rating = agg_rating_raw | times: 1.0
  assign agg_max = agg_max_raw | times: 1.0
  assign agg_pct = 0
  if agg_max > 0
    assign agg_pct = agg_rating | times: 100.0 | divided_by: agg_max | round
  endif
  if agg_pct > 100
    assign agg_pct = 100
  endif
  if agg_pct < 0
    assign agg_pct = 0
  endif
-%}

{%- assign rs_anchor = section.settings.tab_anchor | default: '' | handleize -%}
<section
  id="{% if rs_anchor != blank %}{{ rs_anchor }}{% else %}ReviewSummary-{{ section.id }}{% endif %}"
  class="review-summary color-{{ section.settings.color_scheme }} review-summary--cols-{{ section.settings.columns_desktop }} review-summary--style-{{ section.settings.card_style }} review-summary--summary-{{ section.settings.summary_position }}{% if section.settings.show_summary %} review-summary--with-summary{% endif %}{% if rs_anchor != blank %} pdp-tab-panel{% endif %}"
  {% if rs_anchor != blank %}role="tabpanel" aria-labelledby="{{ rs_anchor }}-tab"{% endif %}
  {% if section.settings.is_default_tab %}data-tab-default="true"{% endif %}
>
  <div class="review-summary__container">
    {%- if section.settings.section_label != blank -%}
      <p class="ig-section-label">{{ section.settings.section_label }}</p>
    {%- endif -%}
    {%- if section.settings.section_heading != blank -%}
      <h2 class="ig-section-title">{{ section.settings.section_heading }}</h2>
    {%- endif -%}

    <div class="review-summary__layout">
      {%- if section.settings.show_summary -%}
        <aside class="review-summary__aggregate" aria-label="Rating summary">
          <div class="review-summary__rating-big">
            <span class="review-summary__rating-num">{{ section.settings.aggregate_rating }}</span>
            <span class="review-summary__rating-outof">/ {{ section.settings.aggregate_rating_out_of }}</span>
          </div>

          <div
            class="review-summary__star-bar"
            role="img"
            aria-label="{{ section.settings.aggregate_rating }} out of {{ section.settings.aggregate_rating_out_of }} stars"
          >
            <div class="review-summary__star-bar-empty" aria-hidden="true">★★★★★</div>
            <div class="review-summary__star-bar-filled" style="width: {{ agg_pct }}%;" aria-hidden="true">
              <span>★★★★★</span>
            </div>
          </div>

          {%- if section.settings.total_reviews != blank -%}
            <div class="review-summary__count ig-section-body">{{ section.settings.total_reviews }}</div>
          {%- endif -%}

          <dl class="review-summary__dist">
            {%- for star in (1..5) reversed -%}
              {%- assign pct_key = 'dist_' | append: star | append: '_star_pct' -%}
              {%- assign pct_raw = section.settings[pct_key] | default: '0' -%}
              {%- assign pct_val = pct_raw | times: 1 -%}
              {%- if pct_val > 100 -%}{%- assign pct_val = 100 -%}{%- endif -%}
              {%- if pct_val < 0 -%}{%- assign pct_val = 0 -%}{%- endif -%}
              <div class="review-summary__dist-row">
                <dt class="review-summary__dist-label">
                  {{ star }}<span class="review-summary__dist-star" aria-hidden="true">★</span>
                </dt>
                <dd class="review-summary__dist-bar-wrap">
                  <div class="review-summary__dist-bar-track" aria-hidden="true">
                    <div class="review-summary__dist-bar-fill" style="width: {{ pct_val }}%;"></div>
                  </div>
                  <span class="review-summary__dist-pct">{{ pct_val }}%</span>
                </dd>
              </div>
            {%- endfor -%}
          </dl>
        </aside>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <div class="review-summary__grid">
          {%- for block in section.blocks -%}
            {%- if block.type == 'review' -%}
              <figure class="review-card" {{ block.shopify_attributes }}>
                <div
                  class="review-card__stars"
                  role="img"
                  aria-label="{{ block.settings.star_rating }} out of 5 stars"
                >
                  {%- for i in (1..5) -%}
                    <span
                      class="review-card__star{% if i <= block.settings.star_rating %} review-card__star--filled{% endif %}"
                      aria-hidden="true"
                    >★</span>
                  {%- endfor -%}
                </div>

                <blockquote class="review-card__quote ig-section-body">
                  {{ block.settings.quote }}
                </blockquote>

                <figcaption class="review-card__cite">
                  {%- if block.settings.reviewer_name != blank -%}
                    <div class="review-card__name">{{ block.settings.reviewer_name }}</div>
                  {%- endif -%}
                  {%- if block.settings.reviewer_meta != blank -%}
                    <div class="review-card__meta">{{ block.settings.reviewer_meta }}</div>
                  {%- endif -%}
                  {%- if block.settings.show_verified or block.settings.product_tag != blank -%}
                    <div class="review-card__badges">
                      {%- if block.settings.show_verified -%}
                        <span class="review-card__verified">
                          <span class="review-card__verified-check" aria-hidden="true">✓</span>
                          Verified customer
                        </span>
                      {%- endif -%}
                      {%- if block.settings.product_tag != blank -%}
                        {%- if block.settings.linked_product != blank -%}
                          <a
                            href="{{ block.settings.linked_product.url }}"
                            class="review-card__product-tag review-card__product-tag--link"
                          >
                            {{ block.settings.product_tag }}
                          </a>
                        {%- else -%}
                          <span class="review-card__product-tag">{{ block.settings.product_tag }}</span>
                        {%- endif -%}
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                </figcaption>
              </figure>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
