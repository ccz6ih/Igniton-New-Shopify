{{ 'component-ig-products-grid.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

{% render 'ig-section-controls', section: section %}

{%- comment -%}
  Section-specific inline overrides the snippet can't emit:
    • product_heading_size  — per-card product name (rem)
    • text_size             — per-card description scale (% of body_size)
  Scoped to this section instance via #IgProductsGrid-{id}.
{%- endcomment -%}
{%- liquid
  assign product_heading_size = section.settings.product_heading_size | default: 2
  assign text_size_pct        = section.settings.text_size | default: 100
  assign text_size_scale      = text_size_pct | divided_by: 100.0
  assign mobile_scale         = section.settings.mobile_heading_scale | default: 65 | divided_by: 100.0
  assign product_heading_m    = product_heading_size | times: mobile_scale
-%}
{%- style -%}
  #IgProductsGrid-{{ section.id }} .ig-product-card__name {
    font-size: {{ product_heading_m }}rem;
  }
  @media screen and (min-width: 750px) {
    #IgProductsGrid-{{ section.id }} .ig-product-card__name {
      font-size: {{ product_heading_size }}rem;
    }
  }

  {%- comment -%} text_size scales the per-card description only {%- endcomment -%}
  #shopify-section-{{ section.id }} .ig-product-card__desc.ig-section-body {
    font-size: calc(var(--ig-body-size, 1rem) * {{ text_size_scale }});
  }
{%- endstyle -%}

<section
  id="IgProductsGrid-{{ section.id }}"
  class="ig-products-grid color-{{ section.settings.color_scheme }}"
>
  <div class="ig-products-grid__container">
    {%- if section.settings.section_label != blank -%}
      <p class="ig-section-label{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
        {{ section.settings.section_label }}
      </p>
    {%- endif -%}

    {%- if section.settings.section_title != blank -%}
      <h2 class="ig-section-title ig-font-display{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
        {{ section.settings.section_title }}
      </h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="ig-products-grid__wrapper{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
        {%- for block in section.blocks -%}
          {%- if block.type == 'product_card' -%}
            {%- liquid
              assign product = block.settings.product
              assign product_name = block.settings.custom_name
              if product_name == blank and product != blank
                assign product_name = product.title
              endif

              assign product_url = block.settings.custom_link
              if product_url == blank and product != blank
                assign product_url = product.url
              endif

              assign product_image = null
              if product != blank
                assign product_image = product.featured_image
              endif

              assign card_classes = 'ig-product-card'
              if block.settings.full_width
                assign card_classes = card_classes | append: ' ig-product-card--full'
              endif
              if block.settings.custom_background != blank
                assign card_classes = card_classes | append: ' ig-product-card--custom-bg'
              endif

              assign card_style = ''
              if block.settings.custom_background != blank
                assign card_style = 'background: ' | append: block.settings.custom_background | append: ';'
              endif

              assign image_max = block.settings.image_size | default: 220
            -%}

            {%- if product_url != blank -%}
              <a
                href="{{ product_url }}"
                class="{{ card_classes }}"
                {% if card_style != '' %}style="{{ card_style }} --ig-product-image-max: {{ image_max }}px;"{% else %}style="--ig-product-image-max: {{ image_max }}px;"{% endif %}
                {{ block.shopify_attributes }}
              >
            {%- else -%}
              <div
                class="{{ card_classes }}"
                {% if card_style != '' %}style="{{ card_style }} --ig-product-image-max: {{ image_max }}px;"{% else %}style="--ig-product-image-max: {{ image_max }}px;"{% endif %}
                {{ block.shopify_attributes }}
              >
            {%- endif -%}

              {%- if block.settings.show_image and product_image != blank -%}
                <div class="ig-product-card__image-wrapper">
                  {{ product_image | image_url: width: 800 | image_tag:
                    loading: 'lazy',
                    class: 'ig-product-card__image',
                    alt: product.title
                  }}
                </div>
              {%- endif -%}

              {%- if block.settings.tag != blank -%}
                <p class="ig-product-card__tag">{{ block.settings.tag }}</p>
              {%- endif -%}

              {%- if product_name != blank -%}
                <h3 class="ig-product-card__name ig-font-display">{{ product_name }}</h3>
              {%- endif -%}

              {%- if block.settings.custom_description != blank -%}
                <div class="ig-product-card__desc ig-section-body ig-font-body">
                  {{ block.settings.custom_description }}
                </div>
              {%- elsif product != blank and product.description != blank -%}
                <div class="ig-product-card__desc ig-section-body ig-font-body">
                  {{ product.description | strip_html | truncatewords: 30 }}
                </div>
              {%- endif -%}

              {%- if block.settings.show_stats -%}
                {%- liquid
                  assign has_any_stat = false
                  for i in (1..3)
                    assign num_key = 'stat_' | append: i | append: '_num'
                    if block.settings[num_key] != blank
                      assign has_any_stat = true
                      break
                    endif
                  endfor
                -%}
                {%- if has_any_stat -%}
                  <div class="ig-product-card__stats">
                    {%- for i in (1..3) -%}
                      {%- assign num_key = 'stat_' | append: i | append: '_num' -%}
                      {%- assign label_key = 'stat_' | append: i | append: '_label' -%}
                      {%- assign stat_num = block.settings[num_key] -%}
                      {%- assign stat_label = block.settings[label_key] -%}
                      {%- if stat_num != blank -%}
                        <div class="ig-product-card__stat">
                          <span class="ig-product-card__stat-num ig-font-display">{{ stat_num }}</span>
                          <span class="ig-product-card__stat-label">{{ stat_label }}</span>
                        </div>
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                {%- endif -%}
              {%- endif -%}

              {%- if block.settings.show_price -%}
                {%- if block.settings.custom_price != blank -%}
                  <p class="ig-product-card__price ig-section-body">
                    <strong>{{ block.settings.custom_price }}</strong>
                    {%- if block.settings.price_note != blank -%}
                      <span class="ig-product-card__price-note"> · {{ block.settings.price_note }}</span>
                    {%- endif -%}
                  </p>
                {%- elsif product != blank -%}
                  <p class="ig-product-card__price ig-section-body">
                    From <strong>{{ product.price | money }}</strong>
                    {%- if block.settings.price_note != blank -%}
                      <span class="ig-product-card__price-note"> · {{ block.settings.price_note }}</span>
                    {%- endif -%}
                  </p>
                {%- endif -%}
              {%- endif -%}

              {%- if block.settings.link_text != blank -%}
                <span class="ig-product-card__link ig-section-body">
                  {{ block.settings.link_text }}
                </span>
              {%- endif -%}

            {%- if product_url != blank -%}
              </a>
            {%- else -%}
              </div>
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- else -%}
      <div class="ig-products-grid__placeholder">
        <p>Add product cards to showcase your products.</p>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Igniton Products Grid",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Color"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "options": [
        { "value": "narrow",  "label": "Narrow (720px)" },
        { "value": "medium",  "label": "Medium (960px)" },
        { "value": "default", "label": "Default (1200px)" },
        { "value": "wide",    "label": "Wide (1440px)" },
        { "value": "full",    "label": "Full bleed" }
      ],
      "default": "default"
    },
    {
      "type": "header",
      "content": "Spacing — desktop"
    },
    {
      "type": "range",
      "id": "padding_block_start_desktop",
      "min": 0, "max": 200, "step": 4,
      "unit": "px",
      "default": 96,
      "label": "Top padding (desktop)"
    },
    {
      "type": "range",
      "id": "padding_block_end_desktop",
      "min": 0, "max": 200, "step": 4,
      "unit": "px",
      "default": 96,
      "label": "Bottom padding (desktop)"
    },
    {
      "type": "header",
      "content": "Spacing — mobile"
    },
    {
      "type": "range",
      "id": "padding_block_start_mobile",
      "min": 0, "max": 200, "step": 4,
      "unit": "px",
      "default": 48,
      "label": "Top padding (mobile)"
    },
    {
      "type": "range",
      "id": "padding_block_end_mobile",
      "min": 0, "max": 200, "step": 4,
      "unit": "px",
      "default": 48,
      "label": "Bottom padding (mobile)"
    },
    {
      "type": "header",
      "content": "Label"
    },
    {
      "type": "select",
      "id": "label_size",
      "label": "Label size",
      "options": [
        { "value": "60",  "label": "XS (60%)" },
        { "value": "80",  "label": "S (80%)" },
        { "value": "100", "label": "Default (100%)" },
        { "value": "120", "label": "L (120%)" },
        { "value": "150", "label": "XL (150%)" },
        { "value": "180", "label": "XXL (180%)" }
      ],
      "default": "100",
      "info": "Percent of base label size (0.8125rem / 13px)."
    },
    {
      "type": "select",
      "id": "label_spacing",
      "label": "Space below label",
      "options": [
        { "value": "0.25", "label": "Tight" },
        { "value": "0.5",  "label": "Compact" },
        { "value": "0.75", "label": "Normal" },
        { "value": "1.25", "label": "Loose" },
        { "value": "2",    "label": "Spacious" }
      ],
      "default": "0.75"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 2, "max": 8, "step": 0.5,
      "unit": "rem",
      "default": 3,
      "label": "Heading size (desktop)"
    },
    {
      "type": "select",
      "id": "heading_max_width",
      "label": "Heading container width",
      "options": [
        { "value": "600",  "label": "Narrow (600px)" },
        { "value": "900",  "label": "Medium (900px)" },
        { "value": "1200", "label": "Wide (1200px)" },
        { "value": "1400", "label": "Full (1400px)" }
      ],
      "default": "900"
    },
    {
      "type": "select",
      "id": "heading_spacing",
      "label": "Space below heading",
      "options": [
        { "value": "1",    "label": "Tight" },
        { "value": "1.75", "label": "Compact" },
        { "value": "2.5",  "label": "Normal" },
        { "value": "3.5",  "label": "Loose" },
        { "value": "5",    "label": "Spacious" }
      ],
      "default": "3.5"
    },
    {
      "type": "select",
      "id": "mobile_heading_scale",
      "label": "Mobile heading scale",
      "info": "How aggressively the heading shrinks on mobile.",
      "options": [
        { "value": "40",  "label": "Aggressive (40%)" },
        { "value": "55",  "label": "Balanced (55%)" },
        { "value": "65",  "label": "Default (65%)" },
        { "value": "80",  "label": "Gentle (80%)" },
        { "value": "100", "label": "Same as desktop" }
      ],
      "default": "65"
    },
    {
      "type": "header",
      "content": "Body"
    },
    {
      "type": "range",
      "id": "body_size",
      "min": 1, "max": 1.5, "step": 0.1,
      "unit": "rem",
      "default": 1,
      "label": "Body text size",
      "info": "Card description / price / link base size. Minimum 1rem / 16px."
    },
    {
      "type": "select",
      "id": "body_max_width",
      "label": "Body container width",
      "options": [
        { "value": "480", "label": "Narrow (480px)" },
        { "value": "640", "label": "Medium (640px)" },
        { "value": "800", "label": "Wide (800px)" },
        { "value": "1000","label": "Full (1000px)" }
      ],
      "default": "800"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "section_label",
      "default": "Two products. One breakthrough.",
      "label": "Section label"
    },
    {
      "type": "inline_richtext",
      "id": "section_title",
      "default": "Every ingredient enhanced for maximum effect.",
      "label": "Section title"
    },
    {
      "type": "header",
      "content": "Per-card typography"
    },
    {
      "type": "range",
      "id": "product_heading_size",
      "min": 1.2, "max": 4, "step": 0.1,
      "unit": "rem",
      "default": 2,
      "label": "Product name size (desktop)",
      "info": "Size of each card's product name. Scales with mobile heading scale on phones."
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 80, "max": 200, "step": 5,
      "unit": "%",
      "default": 100,
      "label": "Card description scale",
      "info": "Multiplies the per-card description size (percent of Body text size)."
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product Card",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product",
          "info": "When set, the card uses the live product's title, image, price, and URL unless overridden below."
        },
        {
          "type": "header",
          "content": "Image"
        },
        {
          "type": "checkbox",
          "id": "show_image",
          "default": true,
          "label": "Show product image"
        },
        {
          "type": "range",
          "id": "image_size",
          "min": 120, "max": 600, "step": 20,
          "unit": "px",
          "default": 220,
          "label": "Image max width"
        },
        {
          "type": "header",
          "content": "Content"
        },
        {
          "type": "text",
          "id": "tag",
          "default": "Cognition",
          "label": "Product tag"
        },
        {
          "type": "text",
          "id": "custom_name",
          "label": "Custom name",
          "info": "Leave blank to use product title"
        },
        {
          "type": "textarea",
          "id": "custom_description",
          "label": "Custom description",
          "info": "Leave blank to use product description"
        },
        {
          "type": "header",
          "content": "Stats"
        },
        {
          "type": "checkbox",
          "id": "show_stats",
          "default": true,
          "label": "Show stats"
        },
        {
          "type": "text",
          "id": "stat_1_num",
          "default": "100%",
          "label": "Stat 1 - Number"
        },
        {
          "type": "text",
          "id": "stat_1_label",
          "default": "Memory improvement",
          "label": "Stat 1 - Label"
        },
        {
          "type": "text",
          "id": "stat_2_num",
          "default": "83%",
          "label": "Stat 2 - Number"
        },
        {
          "type": "text",
          "id": "stat_2_label",
          "default": "Performance quality",
          "label": "Stat 2 - Label"
        },
        {
          "type": "text",
          "id": "stat_3_num",
          "default": "30 days",
          "label": "Stat 3 - Number"
        },
        {
          "type": "text",
          "id": "stat_3_label",
          "default": "To measurable results",
          "label": "Stat 3 - Label"
        },
        {
          "type": "header",
          "content": "Price and link"
        },
        {
          "type": "checkbox",
          "id": "show_price",
          "default": true,
          "label": "Show product price"
        },
        {
          "type": "text",
          "id": "price_note",
          "default": "Subscribe & save 20%",
          "label": "Price note"
        },
        {
          "type": "text",
          "id": "custom_price",
          "label": "Custom price",
          "info": "Leave blank to use live product price"
        },
        {
          "type": "url",
          "id": "custom_link",
