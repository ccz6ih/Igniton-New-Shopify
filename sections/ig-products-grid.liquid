{{ 'component-ig-products-grid.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign text_scale = section.settings.text_size | divided_by: 100.0
  assign tag_scale = section.settings.tag_size | divided_by: 100.0
  assign stat_label_scale = section.settings.stat_label_size | divided_by: 100.0
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  #IgProductsGrid-{{ section.id }} .ig-section-title {
    font-size: {{ section.settings.heading_size }}rem;
  }

  #IgProductsGrid-{{ section.id }} .ig-product-card__name {
    font-size: {{ section.settings.product_heading_size }}rem;
  }

  #IgProductsGrid-{{ section.id }} .ig-product-card__tag {
    font-size: calc(0.78rem * {{ tag_scale }});
  }

  #IgProductsGrid-{{ section.id }} .ig-product-card__desc {
    font-size: calc(1rem * {{ text_scale }});
    line-height: 1.75;
  }

  #IgProductsGrid-{{ section.id }} .ig-product-card__stat-num {
    font-size: {{ section.settings.stat_num_size }}rem;
    letter-spacing: -0.01em;
    {% if section.settings.stat_color == 'gold' %}
      color: var(--ig-ember);
    {% elsif section.settings.stat_color == 'ink' %}
      color: var(--ig-ink);
    {% endif %}
  }

  #IgProductsGrid-{{ section.id }} .ig-product-card__stat-label {
    font-size: calc(0.78rem * {{ stat_label_scale }});
    letter-spacing: 0.02em;
    line-height: 1.4;
    color: #5a554e;
  }

  #IgProductsGrid-{{ section.id }} .ig-product-card__price {
    font-size: calc(0.95rem * {{ text_scale }});
  }

  #IgProductsGrid-{{ section.id }} .ig-product-card__link {
    font-size: calc(0.85rem * {{ text_scale }});
    letter-spacing: 0.12em;
  }

  @media screen and (max-width: 749px) {
    #IgProductsGrid-{{ section.id }} .ig-section-title {
      font-size: calc({{ section.settings.heading_size }}rem * {{ section.settings.mobile_heading_scale | divided_by: 100.0 }});
    }
    #IgProductsGrid-{{ section.id }} .ig-product-card__name {
      font-size: calc({{ section.settings.product_heading_size }}rem * {{ section.settings.mobile_heading_scale | divided_by: 100.0 }});
    }
    #IgProductsGrid-{{ section.id }} .ig-product-card__stat-num {
      font-size: calc({{ section.settings.stat_num_size }}rem * {{ section.settings.mobile_heading_scale | divided_by: 100.0 }});
    }
  }
{%- endstyle -%}

<section 
  id="IgProductsGrid-{{ section.id }}" 
  class="ig-products-grid section-{{ section.id }}-padding color-{{ section.settings.color_scheme }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}"
>
  <div class="page-width">
    {%- if section.settings.section_label != blank -%}
      <p class="ig-section-label{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
        {{ section.settings.section_label }}
      </p>
    {%- endif -%}

    {%- if section.settings.section_title != blank -%}
      <h2 class="ig-section-title ig-font-display{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
        {{ section.settings.section_title }}
      </h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="ig-products-grid__wrapper{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'product_card' -%}
              {%- liquid
                assign product = block.settings.product
                assign is_full_width = block.settings.full_width
                assign custom_bg = block.settings.custom_background
              -%}

              <a 
                href="{% if product != blank %}{{ product.url }}{% else %}{{ block.settings.custom_link }}{% endif %}" 
                class="ig-product-card{% if is_full_width %} ig-product-card--full{% endif %}{% if custom_bg != blank %} ig-product-card--custom-bg{% endif %}"
                {% if custom_bg != blank %}style="background-color: {{ custom_bg }};"{% endif %}
                {{ block.shopify_attributes }}
              >
                {%- if block.settings.show_image and product != blank and product.featured_image != blank -%}
                  <div class="ig-product-card__image-wrapper" style="--ig-product-image-max: {{ block.settings.image_size }}px;">
                    <img
                      src="{{ product.featured_image | image_url: width: 1200 }}"
                      srcset="{{ product.featured_image | image_url: width: 400 }} 400w,
                              {{ product.featured_image | image_url: width: 800 }} 800w,
                              {{ product.featured_image | image_url: width: 1200 }} 1200w"
                      sizes="(min-width: 990px) {{ block.settings.image_size }}px, (min-width: 750px) 50vw, 100vw"
                      alt="{{ product.featured_image.alt | default: product.title }}"
                      class="ig-product-card__image"
                      loading="lazy"
                      width="{{ block.settings.image_size }}"
                      height="{{ block.settings.image_size }}"
                    >
                  </div>
                {%- endif -%}

                {%- if block.settings.tag != blank -%}
                  <p class="ig-product-card__tag">{{ block.settings.tag }}</p>
                {%- endif -%}

                <h3 class="ig-product-card__name ig-font-display">
                  {% if product != blank and block.settings.custom_name == blank %}
                    {{ product.title }}
                  {% else %}
                    {{ block.settings.custom_name }}
                  {% endif %}
                </h3>

                <div class="ig-product-card__desc ig-font-body">
                  {% if block.settings.custom_description != blank %}
                    {{ block.settings.custom_description }}
                  {% elsif product != blank %}
                    {{ product.description | strip_html | truncate: 180 }}
                  {% else %}
                    <p>Add a product or custom description to complete this card.</p>
                  {% endif %}
                </div>

                {%- if block.settings.show_stats -%}
                  {%- liquid
                    assign has_any = false
                    if block.settings.stat_1_num != blank
                      assign has_any = true
                    endif
                    if block.settings.stat_2_num != blank
                      assign has_any = true
                    endif
                    if block.settings.stat_3_num != blank
                      assign has_any = true
                    endif
                  -%}
                  {%- if has_any -%}
                    <div class="ig-product-card__stats">
                      {%- if block.settings.stat_1_num != blank -%}
                        <div class="ig-product-card__stat">
                          <span class="ig-product-card__stat-num ig-font-display">{{ block.settings.stat_1_num }}</span>
                          <span class="ig-product-card__stat-label ig-font-body">{{ block.settings.stat_1_label }}</span>
                        </div>
                      {%- endif -%}
                      {%- if block.settings.stat_2_num != blank -%}
                        <div class="ig-product-card__stat">
                          <span class="ig-product-card__stat-num ig-font-display">{{ block.settings.stat_2_num }}</span>
                          <span class="ig-product-card__stat-label ig-font-body">{{ block.settings.stat_2_label }}</span>
                        </div>
                      {%- endif -%}
                      {%- if block.settings.stat_3_num != blank -%}
                        <div class="ig-product-card__stat">
                          <span class="ig-product-card__stat-num ig-font-display">{{ block.settings.stat_3_num }}</span>
                          <span class="ig-product-card__stat-label ig-font-body">{{ block.settings.stat_3_label }}</span>
                        </div>
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                {%- endif -%}

                {%- if block.settings.show_price and product != blank -%}
                  <div class="ig-product-card__price ig-font-body">
                    From <strong>{{ product.price | money }}</strong>
                    {%- if block.settings.price_note != blank -%}
                      <span class="ig-product-card__price-note"> · {{ block.settings.price_note }}</span>
                    {%- endif -%}
                  </div>
                {%- elsif block.settings.custom_price != blank -%}
                  <div class="ig-product-card__price ig-font-body">
                    {{ block.settings.custom_price }}
                  </div>
                {%- endif -%}

                <span class="ig-product-card__link ig-font-body">
                  {{ block.settings.link_text | default: 'Shop Now' }} <span class="ig-product-card__arrow">→</span>
                </span>
              </a>
          {%- endcase -%}
        {%- endfor -%}
      </div>
    {%- else -%}
      <div class="ig-products-grid__placeholder">
        <p>Add product cards to showcase your products.</p>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Igniton Products Grid",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "section_label",
      "default": "Two products. One breakthrough.",
      "label": "Section label"
    },
    {
      "type": "inline_richtext",
      "id": "section_title",
      "default": "Every ingredient enhanced for maximum effect.",
      "label": "Section title"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 2,
      "max": 8,
      "step": 0.25,
      "default": 3.5,
      "unit": "rem",
      "label": "Section heading size"
    },
    {
      "type": "range",
      "id": "product_heading_size",
      "min": 1.5,
      "max": 4,
      "step": 0.1,
      "default": 2.4,
      "unit": "rem",
      "label": "Product name size"
    },
    {
      "type": "range",
      "id": "tag_size",
      "min": 60,
      "max": 140,
      "step": 5,
      "default": 95,
      "unit": "%",
      "label": "Tag / eyebrow size"
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 80,
      "max": 180,
      "step": 5,
      "default": 115,
      "unit": "%",
      "label": "Body text size"
    },
    {
      "type": "range",
      "id": "stat_num_size",
      "min": 1.2,
      "max": 4,
      "step": 0.1,
      "default": 2.4,
      "unit": "rem",
      "label": "Stat number size"
    },
    {
      "type": "range",
      "id": "stat_label_size",
      "min": 60,
      "max": 140,
      "step": 5,
      "default": 95,
      "unit": "%",
      "label": "Stat label size"
    },
    {
      "type": "select",
      "id": "stat_color",
      "label": "Stat number color",
      "options": [
        { "value": "ink", "label": "Ink (navy)" },
        { "value": "gold", "label": "Ember gold" }
      ],
      "default": "gold"
    },
    {
      "type": "range",
      "id": "mobile_heading_scale",
      "min": 40,
      "max": 100,
      "step": 5,
      "default": 65,
      "unit": "%",
      "label": "Mobile heading scale",
      "info": "Scales section title, product name, and stat numbers on screens under 750px."
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 5,
      "default": 100,
      "unit": "px",
      "label": "Padding top"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 5,
      "default": 100,
      "unit": "px",
      "label": "Padding bottom"
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product Card",
      "limit": 6,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "header",
          "content": "Product image"
        },
        {
          "type": "checkbox",
          "id": "show_image",
          "default": true,
          "label": "Show product image"
        },
        {
          "type": "range",
          "id": "image_size",
          "min": 80,
          "max": 600,
          "step": 10,
          "default": 220,
          "unit": "px",
          "label": "Image size"
        },
        {
          "type": "header",
          "content": "Content"
        },
        {
          "type": "text",
          "id": "tag",
          "default": "Cognition",
          "label": "Tag text"
        },
        {
          "type": "text",
          "id": "custom_name",
          "label": "Custom name",
          "info": "Leave blank to use product title"
        },
        {
          "type": "textarea",
          "id": "custom_description",
          "label": "Custom description",
          "info": "Leave blank to use product description"
        },
        {
          "type": "header",
          "content": "Stats"
        },
        {
          "type": "checkbox",
          "id": "show_stats",
          "default": true,
          "label": "Show stats"
        },
        {
          "type": "text",
          "id": "stat_1_num",
          "label": "Stat 1 — number",
          "info": "Leave blank to skip"
        },
        {
          "type": "text",
          "id": "stat_1_label",
          "label": "Stat 1 — label"
        },
        {
          "type": "text",
          "id": "stat_2_num",
          "label": "Stat 2 — number"
        },
        {
          "type": "text",
          "id": "stat_2_label",
          "label": "Stat 2 — label"
        },
        {
          "type": "text",
          "id": "stat_3_num",
          "label": "Stat 3 — number"
        },
        {
          "type": "text",
          "id": "stat_3_label",
          "label": "Stat 3 — label"
        },
        {
          "type": "header",
          "content": "Price settings"
        },
        {
          "type": "checkbox",
          "id": "show_price",
          "default": true,
          "label": "Show product price"
        },
        {
          "type": "text",
          "id": "price_note",
          "default": "Subscribe & save 20%",
          "label": "Price note"
        },
        {
          "type": "text",
          "id": "custom_price",
          "label": "Custom price text",
          "info": "Overrides product price if set"
        },
        {
          "type": "header",
          "content": "Link settings"
        },
        {
          "type": "url",
          "id": "custom_link",
          "label": "Custom link",
          "info": "Used if no product is selected"
        },
        {
          "type": "text",
          "id": "link_text",
          "default": "Shop Now →",
          "label": "Link text"
        },
        {
          "type": "header",
          "content": "Card styling"
        },
        {
          "type": "checkbox",
          "id": "full_width",
          "default": false,
          "label": "Full width card",
          "info": "Spans entire grid width (for bundle cards)"
        },
        {
          "type": "color",
          "id": "custom_background",
          "label": "Custom background color",
          "info": "Leave blank for default"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Igniton Products Grid",
      "blocks": [
        {
          "type": "product_card",
          "settings": {
            "tag": "Cognition",
            "custom_name": "IgniCognition™",
            "custom_description": "Clinically proven to improve memory, focus, and mental speed — without stimulants or the inevitable crash.",
            "stat_1_num": "100%",
            "stat_1_label": "Memory improvement",
            "stat_2_num": "83%",
            "stat_2_label": "Performance quality",
            "stat_3_num": "30 days",
            "stat_3_label": "To measurable results"
          }
        },
        {
          "type": "product_card",
          "settings": {
            "tag": "Longevity",
            "custom_name": "IgniLongevity™",
            "custom_description": "Targets the inflammatory and aging biomarkers that predict your 10-year health trajectory.",
            "stat_1_num": "hs-CRP",
            "stat_1_label": "Inflammation marker",
            "stat_2_num": "NAD⁺",
            "stat_2_label": "Cellular energy support",
            "stat_3_num": "60 days",
            "stat_3_label": "To longevity results"
          }
        },
        {
          "type": "product_card",
          "settings": {
            "tag": "Best Value",
            "custom_name": "The Complete Stack — Cognition + Longevity",
            "custom_description": "Both formulas together for comprehensive brain and body support.",
            "show_stats": false,
            "full_width": true,
            "custom_background": "#f5f0e8"
          }
        }
      ]
    }
  ]
}
{% endschema %}
