{{ 'component-ig-hero.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #IgHero-{{ section.id }} {
    --ig-hero-min-height: {{ section.settings.min_height }}px;
  }
  
  #IgHero-{{ section.id }} .ig-hero__orb {
    opacity: {{ section.settings.orb_opacity | divided_by: 100.0 }} !important;
    filter: blur(0px) !important;
    {% if section.settings.orb_position == 'left' %}
      right: auto !important;
      left: 5% !important;
    {% elsif section.settings.orb_position == 'center' %}
      right: auto !important;
      left: 50% !important;
      transform: translate(-50%, -50%) !important;
    {% else %}
      right: 5% !important;
    {% endif %}
  }
  
  #IgHero-{{ section.id }} .ig-hero__headline {
    font-size: calc(var(--font-heading-scale) * {{ section.settings.heading_size }}rem);
  }
  
  #IgHero-{{ section.id }} .ig-hero__sub {
    font-size: calc(1rem * {{ section.settings.text_size | divided_by: 100.0 }});
  }
  
  #IgHero-{{ section.id }} .ig-hero__eyebrow {
    font-size: calc(0.78rem * {{ section.settings.text_size | divided_by: 100.0 }});
  }
{%- endstyle -%}

<section 
  id="IgHero-{{ section.id }}" 
  class="ig-hero ig-hero--anim-{{ section.settings.text_animation }} ig-hero--content-align-{{ section.settings.desktop_content_alignment }} ig-hero--content-align-mobile-{{ section.settings.mobile_content_alignment }} color-{{ section.settings.color_scheme }}"
>
  {%- if section.settings.background_image != blank -%}
    <div class="ig-hero__bg-image">
      {{ section.settings.background_image | image_url: width: 1920 | image_tag: loading: 'lazy', class: 'ig-hero__bg-img', alt: section.settings.background_image.alt }}
    </div>
  {%- endif -%}
  
  {%- if section.settings.show_orb -%}
    <div class="ig-hero__orb" aria-hidden="true"></div>
  {%- endif -%}
  
  <div class="ig-hero__content ig-hero__content--{{ section.settings.desktop_content_position }}">
    <div class="ig-hero__inner page-width">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        
        {%- when 'eyebrow' -%}
          {%- if block.settings.text != blank -%}
            <p class="ig-hero__eyebrow" {{ block.shopify_attributes }}>
              {{ block.settings.text }}
            </p>
          {%- endif -%}
        
        {%- when 'headline' -%}
          {%- if block.settings.heading != blank -%}
            <h1 class="ig-hero__headline ig-font-display" {{ block.shopify_attributes }}>
              {{ block.settings.heading | newline_to_br }}
            </h1>
          {%- endif -%}
        
        {%- when 'subheadline' -%}
          {%- if block.settings.text != blank -%}
            <div class="ig-hero__sub ig-font-body" {{ block.shopify_attributes }}>
              {{ block.settings.text }}
            </div>
          {%- endif -%}
        
        {%- when 'buttons' -%}
          <div class="ig-hero__actions" {{ block.shopify_attributes }}>
            {%- if block.settings.button_label_1 != blank -%}
              <a 
                {% if block.settings.button_link_1 == blank %}
                  role="link" aria-disabled="true"
                {% else %}
                  href="{{ block.settings.button_link_1 }}"
                {% endif %}
                class="ig-btn ig-btn--primary"
              >
                {{ block.settings.button_label_1 | escape }}
              </a>
            {%- endif -%}
            
            {%- if block.settings.button_label_2 != blank -%}
              <a 
                {% if block.settings.button_link_2 == blank %}
                  role="link" aria-disabled="true"
                {% else %}
                  href="{{ block.settings.button_link_2 }}"
                {% endif %}
                class="ig-btn ig-btn--secondary"
              >
                {{ block.settings.button_label_2 | escape }}
              </a>
            {%- endif -%}
          </div>
        
        {%- when 'proof_stats' -%}
          <div class="ig-hero__proof" {{ block.shopify_attributes }}>
            {%- for subblock in block.settings -%}
              {%- comment -%} Proof stats will be rendered from nested blocks {%- endcomment -%}
            {%- endfor -%}
          </div>
        
      {%- endcase -%}
    {%- endfor -%}
    
    {%- comment -%} Render proof stats if any exist {%- endcomment -%}
    {%- assign has_stats = false -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'stat' -%}
        {%- assign has_stats = true -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}
    
    {%- if has_stats -%}
      <div class="ig-hero__proof{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
        {%- assign stat_count = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'stat' -%}
            {%- if stat_count > 0 -%}
              <div class="ig-hero__proof-divider"></div>
            {%- endif -%}
            <div class="ig-hero__proof-item" {{ block.shopify_attributes }}>
              <span class="ig-hero__proof-num ig-font-display">
                {{ block.settings.number }}
                {%- if block.settings.unit != blank -%}
                  <span class="ig-hero__proof-unit">{{ block.settings.unit }}</span>
                {%- endif -%}
              </span>
              <span class="ig-hero__proof-label ig-font-body">{{ block.settings.label }}</span>
            </div>
            {%- assign stat_count = stat_count | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Igniton Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "min_height",
      "min": 400,
      "max": 1000,
      "step": 50,
      "default": 700,
      "unit": "px",
      "label": "Minimum height"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "checkbox",
      "id": "show_orb",
      "default": true,
      "label": "Show decorative orb",
      "info": "Golden gradient orb background element"
    },
    {
      "type": "select",
      "id": "orb_position",
      "label": "Orb position",
      "options": [
        {
          "value": "right",
          "label": "Right"
        },
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        }
      ],
      "default": "right"
    },
    {
      "type": "range",
      "id": "orb_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 80,
      "unit": "%",
      "label": "Orb opacity"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "desktop_content_position",
      "label": "Desktop content position",
      "options": [
        {
          "value": "top-left",
          "label": "Top left"
        },
        {
          "value": "top-center",
          "label": "Top center"
        },
        {
          "value": "top-right",
          "label": "Top right"
        },
        {
          "value": "middle-left",
          "label": "Middle left"
        },
        {
          "value": "middle-center",
          "label": "Middle center"
        },
        {
          "value": "middle-right",
          "label": "Middle right"
        },
        {
          "value": "bottom-left",
          "label": "Bottom left"
        },
        {
          "value": "bottom-center",
          "label": "Bottom center"
        },
        {
          "value": "bottom-right",
          "label": "Bottom right"
        }
      ],
      "default": "middle-left"
    },
    {
      "type": "select",
      "id": "desktop_content_alignment",
      "label": "Desktop content alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left",
      "info": "Text alignment within the positioned content area"
    },
    {
      "type": "select",
      "id": "mobile_content_alignment",
      "label": "Mobile content alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "text_animation",
      "label": "Text animation",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "fade-up",
          "label": "Fade up"
        },
        {
          "value": "fade-in",
          "label": "Fade in"
        },
        {
          "value": "slide-left",
          "label": "Slide from left"
        },
        {
          "value": "slide-right",
          "label": "Slide from right"
        },
        {
          "value": "scale-up",
          "label": "Scale up"
        }
      ],
      "default": "fade-up",
      "info": "Pure CSS animations, no JavaScript required"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 3,
      "max": 8,
      "step": 0.5,
      "default": 5,
      "unit": "rem",
      "label": "Heading size"
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 80,
      "max": 150,
      "step": 5,
      "default": 110,
      "unit": "%",
      "label": "Text size"
    }
  ],
  "blocks": [
    {
      "type": "eyebrow",
      "name": "Eyebrow Text",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "Clinically studied · University proven · No stimulants",
          "label": "Eyebrow text"
        }
      ]
    },
    {
      "type": "headline",
      "name": "Headline",
      "limit": 1,
      "settings": [
        {
          "type": "textarea",
          "id": "heading",
          "default": "Think faster.\nAge slower.\nFeel the difference.",
          "label": "Heading",
          "info": "Use line breaks for dramatic impact. Supports <em>italic</em> formatting."
        }
      ]
    },
    {
      "type": "subheadline",
      "name": "Subheadline",
      "limit": 1,
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "default": "<p>Memory, focus, and cognitive speed — measurably improved in 30 days. Longevity biomarkers reduced. No caffeine, no crash, no fillers.</p>",
          "label": "Subheadline text"
        }
      ]
    },
    {
      "type": "buttons",
      "name": "Buttons",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "button_label_1",
          "default": "Try Igniton",
          "label": "Primary button label"
        },
        {
          "type": "url",
          "id": "button_link_1",
          "label": "Primary button link"
        },
        {
          "type": "text",
          "id": "button_label_2",
          "default": "See the clinical results →",
          "label": "Secondary button label"
        },
        {
          "type": "url",
          "id": "button_link_2",
          "label": "Secondary button link"
        }
      ]
    },
    {
      "type": "stat",
      "name": "Proof Stat",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "default": "100",
          "label": "Number"
        },
        {
          "type": "text",
          "id": "unit",
          "default": "%",
          "label": "Unit (optional)",
          "info": "Leave blank for no unit"
        },
        {
          "type": "text",
          "id": "label",
          "default": "Short-term memory improvement",
          "label": "Label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Igniton Hero",
      "blocks": [
        {
          "type": "eyebrow"
        },
        {
          "type": "headline"
        },
        {
          "type": "subheadline"
        },
        {
          "type": "buttons"
        },
        {
          "type": "stat",
          "settings": {
            "number": "100",
            "unit": "%",
            "label": "Short-term memory improvement"
          }
        },
        {
          "type": "stat",
          "settings": {
            "number": "51",
            "unit": "%",
            "label": "Improvement in attention"
          }
        },
        {
          "type": "stat",
          "settings": {
            "number": "30",
            "unit": "",
            "label": "Days to measurable results"
          }
        },
        {
          "type": "stat",
          "settings": {
            "number": "0",
            "unit": "",
            "label": "Stimulants, fillers, or excipients"
          }
        }
      ]
    }
  ]
}
{% endschema %}
