          "label": "Subheadline text"
        }
      ]
    },
    {
      "type": "buttons",
      "name": "Buttons",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "button_label_1",
          "default": "Try Igniton",
          "label": "Button 1 label"
        },
        {
          "type": "url",
          "id": "button_link_1",
          "label": "Button 1 link"
        },
        {
          "type": "select",
          "id": "button_style_1",
          "label": "Button 1 style",
          "options": [
            { "value": "primary",   "label": "Primary (filled)" },
            { "value": "secondary", "label": "Secondary (outlined)" }
          ],
          "default": "primary"
        },
        {
          "type": "text",
          "id": "button_label_2",
          "default": "See the clinical results →",
          "label": "Button 2 label"
        },
        {
          "type": "url",
          "id": "button_link_2",
          "label": "Button 2 link"
        },
        {
          "type": "select",
          "id": "button_style_2",
          "label": "Button 2 style",
          "options": [
            { "value": "primary",   "label": "Primary (filled)" },
            { "value": "secondary", "label": "Secondary (outlined)" },
            { "value": "link",      "label": "Text link (underlined)" }
          ],
          "default": "link"
        }
      ]
    },
    {
      "type": "stat",
      "name": "Proof Stat",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "default": "100",
          "label": "Number"
        },
        {
          "type": "text",
          "id": "unit",
          "default": "%",
          "label": "Unit (optional)"
        },
        {
          "type": "text",
          "id": "label",
          "default": "Short-term memory improvement",
          "label": "Label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Igniton Hero",
      "blocks": [
        { "type": "eyebrow" },
        { "type": "headline" },
        { "type": "subheadline" },
        { "type": "buttons" },
        { "type": "stat", "settings": { "number": "100", "unit": "%", "label": "Short-term memory improvement" } },
        { "type": "stat", "settings": { "number": "51",  "unit": "%", "label": "Improvement in attention" } },
        { "type": "stat", "settings": { "number": "30",  "unit": "",  "label": "Days to measurable results" } },
        { "type": "stat", "settings": { "number": "0",   "unit": "",  "label": "Stimulants, fillers, or excipients" } }
      ]
    }
  ]
}
{% endschema %}
