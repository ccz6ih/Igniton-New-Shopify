{{ 'component-ig-hero.css' | asset_url | stylesheet_tag }}

{% render 'ig-section-controls', section: section %}

{%- comment -%}
  Hero-specific inline style block — holds values that the
  ig-section-controls snippet can't emit yet:
    • min_height (hero-only control)
    • orb positioning math (position/offset/size are bespoke)
    • text_size (percent of body, outside body_size's 1–1.5rem range)
    • proof_num_size (rem, rendered on the stat number)
  Everything else (padding, container, label/heading/body scale)
  is driven by the snippet.
{%- endcomment -%}
{%- liquid
  assign text_size_pct   = section.settings.text_size     | default: 100
  assign text_size_scale = text_size_pct                  | divided_by: 100.0
  assign orb_image_scale = section.settings.orb_image_scale | default: 100 | divided_by: 100.0
  assign orb_opacity_d   = section.settings.orb_opacity   | default: 35 | divided_by: 100.0
  assign mobile_scale    = section.settings.mobile_heading_scale | default: 65 | divided_by: 100.0
-%}

{%- liquid
  assign heading_size_rem   = section.settings.heading_size | default: 3.5
  assign heading_size_m_rem = heading_size_rem | times: mobile_scale
  assign body_size_rem      = section.settings.body_size    | default: 1
  assign label_size_pct     = section.settings.label_size   | default: 100
  assign label_scale        = label_size_pct | divided_by: 100.0
-%}

{%- style -%}
  #IgHero-{{ section.id }} {
    --ig-hero-text-scale: {{ text_size_scale }};
    --ig-hero-proof-num-size: {{ section.settings.proof_num_size | default: 3 }}rem;
    --ig-hero-min-height: {{ section.settings.min_height | default: 700 }}px;
    --ig-hero-orb-size: {{ section.settings.orb_size | default: 750 }}px;
    --ig-hero-orb-opacity: {{ orb_opacity_d }};
    --ig-hero-orb-offset-x: {{ section.settings.orb_offset_x | default: -8 }}vw;
    --ig-hero-orb-image-scale: {{ orb_image_scale }};
    --ig-hero-mobile-scale: {{ mobile_scale }};
  }

  #IgHero-{{ section.id }} .ig-hero__orb-img {
    object-position: {{ section.settings.orb_image_position | default: 'center center' }};
  }

  {%- comment -%}
    Override ig-section-controls' ID-scoped font-sizes with hero's
    text_size_scale multiplier. Same ID specificity (0,1,1,0) + later
    source order → these win.
  {%- endcomment -%}
  #shopify-section-{{ section.id }} .ig-section-title.ig-hero__headline {
    font-size: {{ heading_size_m_rem | times: text_size_scale }}rem;
  }
  #shopify-section-{{ section.id }} .ig-section-body.ig-hero__sub,
  #shopify-section-{{ section.id }} .ig-section-body.ig-hero__link {
    font-size: {{ body_size_rem | times: text_size_scale }}rem;
  }
  #shopify-section-{{ section.id }} .ig-section-label.ig-hero__eyebrow,
  #shopify-section-{{ section.id }} .ig-section-label.ig-hero__proof-label {
    font-size: calc(0.8125rem * {{ label_scale | times: text_size_scale }});
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .ig-section-title.ig-hero__headline {
      font-size: {{ heading_size_rem | times: text_size_scale }}rem;
    }
  }
{%- endstyle -%}

<section
  id="IgHero-{{ section.id }}"
  class="ig-hero ig-hero--anim-{{ section.settings.text_animation }} ig-hero--content-align-{{ section.settings.desktop_content_alignment }} ig-hero--content-align-mobile-{{ section.settings.mobile_content_alignment }} ig-hero--orb-{{ section.settings.orb_position }} ig-hero--orb-style-{{ section.settings.orb_style }} color-{{ section.settings.color_scheme }}"
>
  {%- if section.settings.background_image != blank -%}
    <div class="ig-hero__bg-image">
      {{ section.settings.background_image | image_url: width: 1920 | image_tag: loading: 'lazy', class: 'ig-hero__bg-img', alt: section.settings.background_image.alt }}
    </div>
  {%- endif -%}

  {%- if section.settings.show_orb -%}
    <div class="ig-hero__orb ig-hero__orb--{{ section.settings.orb_style }}" aria-hidden="true">
      {%- if section.settings.orb_image != blank -%}
        {{ section.settings.orb_image | image_url: width: 1400 | image_tag:
          loading: 'eager',
          class: 'ig-hero__orb-img',
          alt: section.settings.orb_image.alt
        }}
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="ig-hero__content ig-hero__content--{{ section.settings.desktop_content_position }}">
    <div class="ig-hero__inner">
      {%- for block in section.blocks -%}
        {%- case block.type -%}

          {%- when 'eyebrow' -%}
            {%- if block.settings.text != blank -%}
              <p class="ig-section-label ig-hero__eyebrow" {{ block.shopify_attributes }}>
                {{ block.settings.text }}
              </p>
            {%- endif -%}

          {%- when 'headline' -%}
            {%- if block.settings.heading != blank -%}
              <h1 class="ig-section-title ig-hero__headline ig-font-display" {{ block.shopify_attributes }}>
                {{ block.settings.heading | newline_to_br }}
              </h1>
            {%- endif -%}

          {%- when 'subheadline' -%}
            {%- if block.settings.text != blank -%}
              <div class="ig-section-body ig-hero__sub ig-font-body" {{ block.shopify_attributes }}>
                {{ block.settings.text }}
              </div>
            {%- endif -%}

          {%- when 'buttons' -%}
            <div class="ig-hero__actions" {{ block.shopify_attributes }}>
              {%- if block.settings.button_label_1 != blank -%}
                <a
                  {% if block.settings.button_link_1 == blank %}role="link" aria-disabled="true"{% else %}href="{{ block.settings.button_link_1 }}"{% endif %}
                  class="button{% if block.settings.button_style_1 == 'secondary' %} button--secondary{% else %} button--primary{% endif %}"
                >
                  {{ block.settings.button_label_1 | escape }}
                </a>
              {%- endif -%}

              {%- if block.settings.button_label_2 != blank -%}
                <a
                  {% if block.settings.button_link_2 == blank %}role="link" aria-disabled="true"{% else %}href="{{ block.settings.button_link_2 }}"{% endif %}
                  class="{% if block.settings.button_style_2 == 'link' %}ig-hero__link ig-section-body{% else %}button{% if block.settings.button_style_2 == 'primary' %} button--primary{% else %} button--secondary{% endif %}{% endif %}"
                >
                  {{ block.settings.button_label_2 | escape }}
                </a>
              {%- endif -%}
            </div>

        {%- endcase -%}
      {%- endfor -%}

      {%- comment -%} Render proof stats if any exist {%- endcomment -%}
      {%- assign has_stats = false -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'stat' -%}
          {%- assign has_stats = true -%}
          {%- break -%}
        {%- endif -%}
      {%- endfor -%}

      {%- if has_stats -%}
        <div class="ig-hero__proof{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
          {%- assign stat_count = 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'stat' -%}
              {%- if stat_count > 0 -%}
                <div class="ig-hero__proof-divider"></div>
              {%- endif -%}
              <div class="ig-hero__proof-item" {{ block.shopify_attributes }}>
                <span class="ig-hero__proof-num ig-font-display">
                  {{ block.settings.number }}
                  {%- if block.settings.unit != blank -%}
                    <span class="ig-hero__proof-unit">{{ block.settings.unit }}</span>
                  {%- endif -%}
                </span>
                <span class="ig-section-label ig-hero__proof-label ig-font-body">{{ block.settings.label }}</span>
              </div>
              {%- assign stat_count = stat_count | plus: 1 -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Igniton Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Color"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "options": [
        { "value": "narrow",  "label": "Narrow (720px)" },
        { "value": "medium",  "label": "Medium (960px)" },
        { "value": "default", "label": "Default (1200px)" },
        { "value": "wide",    "label": "Wide (1440px)" },
        { "value": "full",    "label": "Full bleed" }
      ],
      "default": "default"
    },
    {
      "type": "range",
      "id": "min_height",
      "min": 400, "max": 1000, "step": 50,
      "unit": "px",
      "default": 700,
      "label": "Minimum height"
    },
    {
      "type": "header",
      "content": "Spacing — desktop"
    },
    {
      "type": "range",
      "id": "padding_block_start_desktop",
      "min": 0, "max": 200, "step": 4,
      "unit": "px",
      "default": 120,
      "label": "Top padding (desktop)"
    },
    {
      "type": "range",
      "id": "padding_block_end_desktop",
      "min": 0, "max": 200, "step": 4,
      "unit": "px",
      "default": 120,
      "label": "Bottom padding (desktop)"
    },
    {
      "type": "header",
      "content": "Spacing — mobile"
    },
    {
      "type": "select",
      "id": "padding_block_start_mobile",
      "label": "Top padding (mobile)",
      "options": [
        { "value": "0",   "label": "None" },
        { "value": "24",  "label": "Tight (24px)" },
        { "value": "48",  "label": "Compact (48px)" },
        { "value": "64",  "label": "Normal (64px)" },
        { "value": "96",  "label": "Loose (96px)" },
        { "value": "128", "label": "Spacious (128px)" }
      ],
      "default": "64"
    },
    {
      "type": "select",
      "id": "padding_block_end_mobile",
      "label": "Bottom padding (mobile)",
      "options": [
        { "value": "0",   "label": "None" },
        { "value": "24",  "label": "Tight (24px)" },
        { "value": "48",  "label": "Compact (48px)" },
        { "value": "64",  "label": "Normal (64px)" },
        { "value": "96",  "label": "Loose (96px)" },
        { "value": "128", "label": "Spacious (128px)" }
      ],
      "default": "64"
    },
    {
      "type": "header",
      "content": "Label"
    },
    {
      "type": "range",
      "id": "label_size",
      "min": 60, "max": 220, "step": 5,
      "unit": "%",
      "default": 100,
      "label": "Label size",
      "info": "Percent of base label size (0.8125rem / 13px). Also controls proof stat labels."
    },
    {
      "type": "select",
      "id": "label_spacing",
      "label": "Space below label",
      "options": [
        { "value": "0.25", "label": "Tight" },
        { "value": "0.5",  "label": "Compact" },
        { "value": "0.75", "label": "Normal" },
        { "value": "1.25", "label": "Loose" },
        { "value": "2",    "label": "Spacious" }
      ],
      "default": "1.25"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 2, "max": 12, "step": 0.5,
      "unit": "rem",
      "default": 3.5,
      "label": "Heading size (desktop)"
    },
    {
      "type": "select",
      "id": "heading_max_width",
      "label": "Heading container width",
      "options": [
        { "value": "600",  "label": "Narrow (600px)" },
        { "value": "900",  "label": "Medium (900px)" },
        { "value": "1200", "label": "Wide (1200px)" },
        { "value": "1400", "label": "Full (1400px)" }
      ],
      "default": "1200"
    },
    {
      "type": "select",
      "id": "heading_spacing",
      "label": "Space below heading",
      "options": [
        { "value": "1",    "label": "Tight" },
        { "value": "1.75", "label": "Compact" },
        { "value": "2.5",  "label": "Normal" },
        { "value": "3.5",  "label": "Loose" },
        { "value": "5",    "label": "Spacious" }
      ],
      "default": "2.5"
    },
    {
      "type": "range",
      "id": "mobile_heading_scale",
      "min": 40, "max": 100, "step": 5,
      "unit": "%",
      "default": 55,
      "label": "Mobile heading scale",
      "info": "How aggressively the heading shrinks on mobile (as a % of desktop size)."
    },
    {
      "type": "header",
      "content": "Body"
    },
    {
      "type": "range",
      "id": "body_size",
      "min": 1, "max": 1.5, "step": 0.1,
      "unit": "rem",
      "default": 1.1,
      "label": "Body text size",
      "info": "Subheadline and text-link base size. Minimum 1rem / 16px."
    },
    {
      "type": "select",
      "id": "body_max_width",
      "label": "Body container width",
      "options": [
        { "value": "400", "label": "Narrow (400px)" },
        { "value": "480", "label": "Medium (480px)" },
        { "value": "640", "label": "Wide (640px)" },
        { "value": "800", "label": "Full (800px)" }
      ],
      "default": "480"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "header",
      "content": "Orb"
    },
    {
      "type": "checkbox",
      "id": "show_orb",
      "default": true,
      "label": "Show orb",
      "info": "Circular decorative element. Shows a photo if uploaded, otherwise a gradient."
    },
    {
      "type": "image_picker",
      "id": "orb_image",
      "label": "Orb image (optional)"
    },
    {
      "type": "select",
      "id": "orb_image_position",
      "label": "Image focal point",
      "options": [
        { "value": "center center", "label": "Center" },
        { "value": "center top",    "label": "Top" },
        { "value": "center bottom", "label": "Bottom" },
        { "value": "left center",   "label": "Left" },
        { "value": "right center",  "label": "Right" }
      ],
      "default": "center center"
    },
    {
      "type": "range",
      "id": "orb_image_scale",
      "min": 80, "max": 180, "step": 5,
      "unit": "%",
      "default": 100,
      "label": "Image zoom"
    },
    {
      "type": "select",
      "id": "orb_style",
      "label": "Orb color style",
      "options": [
        { "value": "warm",  "label": "Warm cream (soft)" },
        { "value": "cream", "label": "Pale cream (softest)" },
        { "value": "gold",  "label": "Gold (richer)" },
        { "value": "amber", "label": "Amber (warmest)" }
      ],
      "default": "warm"
    },
    {
      "type": "select",
      "id": "orb_position",
      "label": "Orb position",
      "options": [
        { "value": "right",  "label": "Right" },
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "right"
    },
    {
      "type": "range",
      "id": "orb_offset_x",
      "min": -20, "max": 20, "step": 1,
      "unit": "vw",
      "default": -8,
      "label": "Orb horizontal offset"
    },
    {
      "type": "range",
      "id": "orb_size",
      "min": 300, "max": 1200, "step": 25,
      "unit": "px",
      "default": 750,
      "label": "Orb size"
    },
    {
      "type": "range",
      "id": "orb_opacity",
      "min": 0, "max": 100, "step": 5,
      "unit": "%",
      "default": 35,
      "label": "Orb opacity"
    },
    {
      "type": "header",
      "content": "Content positioning"
    },
    {
      "type": "select",
      "id": "desktop_content_position",
      "label": "Desktop content position",
      "options": [
        { "value": "top-left",      "label": "Top left" },
        { "value": "top-center",    "label": "Top center" },
        { "value": "top-right",     "label": "Top right" },
        { "value": "middle-left",   "label": "Middle left" },
        { "value": "middle-center", "label": "Middle center" },
        { "value": "middle-right",  "label": "Middle right" },
        { "value": "bottom-left",   "label": "Bottom left" },
        { "value": "bottom-center", "label": "Bottom center" },
        { "value": "bottom-right",  "label": "Bottom right" }
      ],
      "default": "middle-left"
    },
    {
      "type": "select",
      "id": "desktop_content_alignment",
      "label": "Desktop text alignment",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "mobile_content_alignment",
      "label": "Mobile text alignment",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "text_animation",
      "label": "Text animation",
      "options": [
        { "value": "none",        "label": "None" },
        { "value": "fade-up",     "label": "Fade up" },
        { "value": "fade-in",     "label": "Fade in" },
        { "value": "slide-left",  "label": "Slide from left" },
        { "value": "slide-right", "label": "Slide from right" },
        { "value": "scale-up",    "label": "Scale up" }
      ],
      "default": "fade-up"
    },
    {
      "type": "header",
      "content": "Proof stats"
    },
    {
      "type": "range",
      "id": "proof_num_size",
      "min": 2, "max": 8, "step": 0.1,
      "unit": "rem",
      "default": 3,
      "label": "Stat number size (desktop)",
      "info": "Size of the large stat numbers. Scales with mobile heading scale on phones."
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 80, "max": 200, "step": 5,
      "unit": "%",
      "default": 100,
      "label": "Overall text scale",
      "info": "Multiplies the entire hero's text (headline, subheadline, stat labels). Use body_size for subheadline-only sizing in rem."
    }
  ],
  "blocks": [
    {
      "type": "eyebrow",
      "name": "Eyebrow Text",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "Clinically studied · University proven · No stimulants",
          "label": "Eyebrow text"
        }
      ]
    },
    {
      "type": "headline",
      "name": "Headline",
      "limit": 1,
      "settings": [
        {
          "type": "textarea",
          "id": "heading",
          "default": "Think faster.\nAge <em>slower.</em>\nFeel the difference.",
          "label": "Heading",
          "info": "Use line breaks for dramatic impact. Supports <em>italic</em> and <br> formatting."
        }
      ]
    },
    {
      "type": "subheadline",
      "name": "Subheadline",
      "limit": 1,
      "settings": [
        {
