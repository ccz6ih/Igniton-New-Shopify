    "tab_faq": {
      "type": "faq",
      "blocks": {
        "faq_timing": {
          "type": "item",
          "settings": {
            "question": "When will I feel the difference?",
            "answer": "<p>Most users notice clearer thinking and smoother energy within 1–2 weeks. The clinical trial measured significant cognitive improvements at 30 days, with peak results at 90 days.</p>"
          }
        },
        "faq_stimulants": {
          "type": "item",
          "settings": {
            "question": "Does it contain caffeine or stimulants?",
            "answer": "<p>None. Zero caffeine, zero synthetic stimulants. Cognitive benefits come from enhanced cellular function and neurotransmitter support — not stimulation. No crash, no sleep disruption.</p>"
          }
        },
        "faq_price": {
          "type": "item",
          "settings": {
            "question": "Why does it cost more than other nootropics?",
            "answer": "<p>Two reasons: ingredient quality and the enhancement process. Every compound is GRAS-certified with zero fillers. The cold plasma and laser-photonics process significantly increases manufacturing cost — but is why the formula outperforms the same ingredients unenhanced in head-to-head trials.</p>"
          }
        },
        "faq_stack": {
          "type": "item",
          "settings": {
            "question": "Can I take it alongside IgniLongevity™?",
            "answer": "<p>Yes — the two products are designed to complement each other. Most users take IgniCognition in the morning and IgniLongevity in the afternoon for comprehensive support.</p>"
          }
        },
        "faq_returns": {
          "type": "item",
          "settings": {
            "question": "What's the return policy?",
            "answer": "<p>If you don't feel a measurable difference within 30 days of consistent use, we'll refund you in full — no questions asked.</p>"
          }
        },
        "faq_vegan": {
          "type": "item",
          "settings": {
            "question": "Is it vegan and allergen-free?",
            "answer": "<p>Yes — vegan, non-GMO, gluten-free, no artificial colors or preservatives, no fillers, no binders.</p>"
          }
        }
      },
